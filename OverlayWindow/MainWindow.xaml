<Window x:Class="OverlayWindow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OverlayWindow"
        Title="GCM Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        Width="400"
        Height="{x:Static SystemParameters.PrimaryScreenHeight}"
        WindowStartupLocation="Manual"
        Left="{x:Static SystemParameters.PrimaryScreenWidth}"
        Top="0"
        Deactivated="Window_Deactivated"
        >

    <Border Background="#FF1E1E1E">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="RootPanel" Orientation="Vertical" Margin="16">

                <!-- SHORTCUT CATEGORY -->
                <Expander x:Name="ShortcutExpander"
                          Header="SHORTCUTS"
                          Foreground="White"
                          Background="#222"
                          FontSize="22"
                          FontWeight="Bold"
                          Padding="12"
                          BorderBrush="Gray"
                          BorderThickness="1"
                          ExpandDirection="Down"
                          Margin="0,0,0,10">

                    <ItemsControl x:Name="ShortcutList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#333"
                                        CornerRadius="10"
                                        Padding="10"
                                        Margin="5">
                                    <DockPanel>
                                        <Image Source="pack://application:,,,/OverlayWindow;component/Assets/controller.png"
                                               Width="32" Height="32" Margin="0,0,10,0"
                                               DockPanel.Dock="Left"/>
                                        <StackPanel>
                                            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="White">
                                                <Run Text="{Binding Key1}"/>
                                                <Run Text=" + "/>
                                                <Run Text="{Binding Key2}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="14" Foreground="Gray" Text="{Binding Function}"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

                <!-- Weitere Kategorien folgen hier -->

            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
