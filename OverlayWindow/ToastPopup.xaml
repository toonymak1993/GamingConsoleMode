 <Window x:Class="OverlayWindow.ToastPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Width="400" Height="80"
        Loaded="Window_Loaded">

    <Grid Margin="10">
        <!-- Schatten-Background (leicht versetzt) -->
        <Border Background="#55000000"
            CornerRadius="12"
            Margin="4,4,0,0" />

        <!-- Haupt-Toast-Inhalt -->
        <Border Background="#DD333333"
            CornerRadius="12"
            Padding="12">
            <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <TextBlock x:Name="ToastIcon"
                       FontSize="20"
                       VerticalAlignment="Center"
                       Foreground="White"
                       Margin="0,0,10,0" />
                <TextBlock x:Name="ToastText"
                       Text="Placeholder"
                       Foreground="White"
                       FontSize="18"
                       TextWrapping="Wrap"
                       TextAlignment="Left" />
            </StackPanel>
        </Border>
    </Grid>

</Window>