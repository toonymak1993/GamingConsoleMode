<Page
    x:Class="GAMINGCONSOLEMODE.Onboarding"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="Transparent">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="WindowSizeStates">
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="850" />
                    </VisualState.StateTriggers>
                </VisualState>

                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="Step1Text.Visibility" Value="Collapsed" />
                        <Setter Target="Step2Text.Visibility" Value="Collapsed" />
                        <Setter Target="Step3Text.Visibility" Value="Collapsed" />
                        <Setter Target="Step4Text.Visibility" Value="Collapsed" />
                        <Setter Target="Step5Text.Visibility" Value="Collapsed" />
                        <Setter Target="StepperHeader.Margin" Value="0,15,0,10" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel x:Name="StepperHeader" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,40,0,20" Spacing="12">

            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Border x:Name="Step1Indicator" Width="32" Height="32" CornerRadius="16">
                    <TextBlock x:Name="Step1Number" Text="1" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock x:Name="Step1Text" Text="Welcome" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>

            <FontIcon x:Name="Arrow1" Glyph="&#xE0AD;" FontSize="12" VerticalAlignment="Center" Opacity="0.5" />

            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Border x:Name="Step2Indicator" Width="32" Height="32" CornerRadius="16">
                    <TextBlock x:Name="Step2Number" Text="2" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock x:Name="Step2Text" Text="Autostart" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>

            <FontIcon x:Name="Arrow2" Glyph="&#xE0AD;" FontSize="12" VerticalAlignment="Center" Opacity="0.5" />

            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Border x:Name="Step3Indicator" Width="32" Height="32" CornerRadius="16">
                    <TextBlock x:Name="Step3Number" Text="3" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock x:Name="Step3Text" Text="Autologon" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>

            <FontIcon x:Name="Arrow3" Glyph="&#xE0AD;" FontSize="12" VerticalAlignment="Center" Opacity="0.5" />

            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Border x:Name="Step4Indicator" Width="32" Height="32" CornerRadius="16">
                    <TextBlock x:Name="Step4Number" Text="4" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock x:Name="Step4Text" Text="Artwork" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>

            <FontIcon x:Name="Arrow4" Glyph="&#xE0AD;" FontSize="12" VerticalAlignment="Center" Opacity="0.5" />

            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Border x:Name="Step5Indicator" Width="32" Height="32" CornerRadius="16">
                    <TextBlock x:Name="Step5Number" Text="5" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock x:Name="Step5Text" Text="Finish" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>

        </StackPanel>

        <FlipView x:Name="OnboardingFlipView" Grid.Row="1" SelectionChanged="OnboardingFlipView_SelectionChanged">

            <FlipViewItem>
                <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15" MaxWidth="600" Padding="20">
                        <Image Source="Assets/gcm_ui_logo.png" MaxHeight="180" Margin="0,0,0,10"/>
                        <TextBlock Text="Getting Started with GCM" FontSize="36" FontWeight="SemiBold" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                        <TextBlock Text="Master your controller shortcuts and learn how to get the most out of GameConsoleMode." FontSize="18" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,10" />
                        <Button x:Name="onboarding" Content="Open Onboarding information" Click="onboarding_Click" IsEnabled="True" HorizontalAlignment="Center" Width="260" Height="50" FontSize="16" Style="{StaticResource AccentButtonStyle}" CornerRadius="25"/>
                    </StackPanel>
                </Viewbox>
            </FlipViewItem>

            <FlipViewItem>
                <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15" MaxWidth="600" Padding="20">
                        <Image Source="Assets/onboarding/shortcuts.png" MaxHeight="160" Margin="0,0,0,10"/>
                        <TextBlock Text="Autostart Management" FontSize="36" FontWeight="SemiBold" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                        <TextBlock Text="GCM can control your autostart apps so that nothing pops up at startup. You might need to manually deactivate some launchers like Rog AC." FontSize="18" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center" />
                        <ToggleSwitch x:Name="AutostartToggle" Header="Autostart Management" OnContent="On" OffContent="Off" Toggled="AutostartToggle_Toggled" HorizontalAlignment="Center" Margin="0,15,0,0" />
                    </StackPanel>
                </Viewbox>
            </FlipViewItem>

            <FlipViewItem>
                <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15" MaxWidth="600" Padding="20">
                        <Image Source="/functions/winpart.png" MaxHeight="180" Margin="0,0,0,10"/>
                        <TextBlock Text="Automatic Logon" FontSize="36" FontWeight="SemiBold" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                        <TextBlock Text="Download the official Windows tool so you don't have to enter your password at startup." FontSize="18" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center" />
                        <Button x:Name="autologon" Content="Windows Autologon" Click="autologon_Click" IsEnabled="True" HorizontalAlignment="Center" Width="260" Height="50" FontSize="16" Style="{StaticResource DefaultButtonStyle}" CornerRadius="25"/>
                    </StackPanel>
                </Viewbox>
            </FlipViewItem>

            <FlipViewItem>
                <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15" MaxWidth="600" Padding="20">
                        <Image Source="Assets/game.png" MaxHeight="160" Margin="0,0,0,10"/>
                        <TextBlock Text="Game Artwork" FontSize="36" FontWeight="SemiBold" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                        <TextBlock Text="GCM uses SteamGridDB to fetch high-quality covers for your games. We highly recommend getting a free API Key for the best visual experience." FontSize="18" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center" />

                        <TextBox x:Name="ApiKeyBox" PlaceholderText="Paste your API Key here (starts with a hash...)" Width="400" HorizontalAlignment="Center" TextChanged="ApiKeyBox_TextChanged" Margin="0,10,0,0"/>

                        <Button x:Name="GetApiKeyButton" Content="Get free API Key" Click="GetApiKeyButton_Click" HorizontalAlignment="Center" Width="200" Style="{StaticResource AccentButtonStyle}" CornerRadius="20" Margin="0,5,0,0"/>

                        <TextBlock Text="1. Login to SteamGridDB &#x0a;2. Generate Key &#x0a;3. Copy &amp; Paste it here" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Viewbox>
            </FlipViewItem>

            <FlipViewItem>
                <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15" MaxWidth="600" Padding="20">
                        <Image Source="/Assets/onboarding/discord.jpg" MaxHeight="180" Margin="0,0,0,10"/>
                        <TextBlock Text="You're all set!" FontSize="36" FontWeight="SemiBold" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                        <TextBlock Text="Support, Suggestions, Updates and Community" FontSize="18" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center" />
                        <Button x:Name="DiscordButton" Content="Join our Community" HorizontalAlignment="Center" Margin="0,15,0,0" Click="DiscordButton_Click" Width="260" Height="50" FontSize="16" Style="{StaticResource AccentButtonStyle}" CornerRadius="25"/>
                    </StackPanel>
                </Viewbox>
            </FlipViewItem>

        </FlipView>

        <Grid Grid.Row="2" Margin="24,10,24,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="BackButton" Content="Back" Width="120" HorizontalAlignment="Left" Click="BackButton_Click" IsEnabled="False" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                <Button x:Name="NextButton" Content="Next" Width="120" Style="{StaticResource AccentButtonStyle}" Click="NextButton_Click" />
                <Button x:Name="FinishButton" Content="Finish" Width="120" Style="{StaticResource AccentButtonStyle}" Click="FinishButton_Click" Visibility="Collapsed" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>