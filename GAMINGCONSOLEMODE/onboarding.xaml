<Page
    x:Class="GAMINGCONSOLEMODE.Onboarding"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel x:Name="StepperHeader" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,40,0,20" Spacing="12">

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Border x:Name="Step1Indicator" Width="32" Height="32" CornerRadius="16">
                    <TextBlock x:Name="Step1Number" Text="1" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock x:Name="Step1Text" Text="Welcome" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>

            <FontIcon x:Name="Arrow1" Glyph="&#xE0AD;" FontSize="16" VerticalAlignment="Center" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Border x:Name="Step2Indicator" Width="32" Height="32" CornerRadius="16">
                    <TextBlock x:Name="Step2Number" Text="2" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock x:Name="Step2Text" Text="Shortcuts" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>

            <FontIcon x:Name="Arrow2" Glyph="&#xE0AD;" FontSize="16" VerticalAlignment="Center" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Border x:Name="Step3Indicator" Width="32" Height="32" CornerRadius="16">
                    <TextBlock x:Name="Step3Number" Text="3" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock x:Name="Step3Text" Text="Finish" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>

        </StackPanel>

        <FlipView x:Name="OnboardingFlipView" Grid.Row="1" SelectionChanged="OnboardingFlipView_SelectionChanged">

            <FlipViewItem>
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10" MaxWidth="600">
                        <TextBlock Text="Getting Started with GCM"
                                   FontSize="42" FontWeight="SemiBold" HorizontalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center" />
                        <TextBlock Text="Master your controller shortcuts and learn how to get the most out of GameConsoleMode."
                                   FontSize="20" HorizontalAlignment="Center" Foreground="Gray"
                                   TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>
                </Grid>
            </FlipViewItem>

            <FlipViewItem>
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10" MaxWidth="600">
                        <TextBlock Text="Controller Legend"
                                   FontSize="42" FontWeight="SemiBold" HorizontalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center" />
                        <TextBlock Text="Quick reference for all controller shortcuts."
                                   FontSize="20" HorizontalAlignment="Center" Foreground="Gray"
                                   TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>
                </Grid>
            </FlipViewItem>

            <FlipViewItem>
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10" MaxWidth="600">
                        <TextBlock Text="You're all set!"
                                   FontSize="42" FontWeight="SemiBold" HorizontalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center" />
                        <TextBlock Text="You can change all settings later. Click 'Start GCM' (in the main window) to begin."
                                   FontSize="20" HorizontalAlignment="Center" Foreground="Gray"
                                   TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>
                </Grid>
            </FlipViewItem>

        </FlipView>

        <Grid Grid.Row="2" Margin="0,20,0,40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button x:Name="BackButton" Content="Back" Grid.Column="1" Margin="0,0,10,0" Click="BackButton_Click" IsEnabled="False" />

            <Button x:Name="NextButton" Content="Next" Grid.Column="2" Style="{StaticResource AccentButtonStyle}" Click="NextButton_Click" />
            <Button x:Name="FinishButton" Content="Finish" Grid.Column="2" Style="{StaticResource AccentButtonStyle}" Click="FinishButton_Click" Visibility="Collapsed" />
        </Grid>
    </Grid>
</Page>