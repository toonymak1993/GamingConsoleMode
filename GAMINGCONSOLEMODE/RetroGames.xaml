<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GAMINGCONSOLEMODE.RetroGames"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:GAMINGCONSOLEMODE"
    xmlns:webview2="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#1A1A2E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="#16213E" Padding="20,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                <TextBlock Text="&#xE768;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="24"
                           Foreground="#E94560"
                           VerticalAlignment="Center"/>
                <StackPanel>
                    <TextBlock Text="Retro Games"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Classic games playable directly in XlineGame"
                               FontSize="12"
                               Foreground="#AAAAAA"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button x:Name="BackButton" Content="&#xE72B;" FontFamily="Segoe MDL2 Assets"
                        Click="BackButton_Click" ToolTipService.ToolTip="Back"
                        Background="#0F3460" Foreground="White" BorderBrush="Transparent"
                        Width="40" Height="40" CornerRadius="4"/>
                <Button x:Name="ForwardButton" Content="&#xE72A;" FontFamily="Segoe MDL2 Assets"
                        Click="ForwardButton_Click" ToolTipService.ToolTip="Forward"
                        Background="#0F3460" Foreground="White" BorderBrush="Transparent"
                        Width="40" Height="40" CornerRadius="4"/>
                <Button x:Name="HomeButton" Content="&#xE80F;" FontFamily="Segoe MDL2 Assets"
                        Click="HomeButton_Click" ToolTipService.ToolTip="Home"
                        Background="#E94560" Foreground="White" BorderBrush="Transparent"
                        Width="40" Height="40" CornerRadius="4"/>
                <Button x:Name="RefreshButton" Content="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                        Click="RefreshButton_Click" ToolTipService.ToolTip="Refresh"
                        Background="#0F3460" Foreground="White" BorderBrush="Transparent"
                        Width="40" Height="40" CornerRadius="4"/>
            </StackPanel>
        </Grid>

        <!-- Address bar -->
        <Grid Grid.Row="1" Background="#0F3460" Padding="20,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets"
                       Foreground="#E94560" VerticalAlignment="Center"
                       Margin="0,0,10,0" FontSize="14"/>
            <TextBlock x:Name="AddressBar"
                       Grid.Column="1"
                       Text="https://classicgamezone.com"
                       Foreground="#CCCCCC"
                       FontSize="12"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- Loading overlay -->
        <Grid Grid.Row="2">
            <webview2:WebView2 x:Name="RetroWebView"
                               Source="https://classicgamezone.com"
                               NavigationStarting="RetroWebView_NavigationStarting"
                               NavigationCompleted="RetroWebView_NavigationCompleted"
                               CoreWebView2Initialized="RetroWebView_CoreWebView2Initialized"/>

            <Grid x:Name="LoadingOverlay" Background="#1A1A2E" Visibility="Visible">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                    <ProgressRing IsActive="True" Width="60" Height="60" Foreground="#E94560"/>
                    <TextBlock Text="Loading Retro Games..."
                               Foreground="White" FontSize="16"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="classicgamezone.com"
                               Foreground="#888888" FontSize="12"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
