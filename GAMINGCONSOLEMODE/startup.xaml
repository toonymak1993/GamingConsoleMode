<Page
    x:Class="GAMINGCONSOLEMODE.startup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="using:Microsoft.UI.Xaml.Controls"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Page.Background>
        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
            <GradientStop Color="#1E1E1E" Offset="0.0"/>
            <GradientStop Color="#121212" Offset="1.0"/>
        </LinearGradientBrush>
    </Page.Background>

    <Page.Resources>
        <Style TargetType="Button" x:Key="ModernCardButtonStyle">
            <Setter Property="Width" Value="280"/>
            <Setter Property="Height" Value="160"/>
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="ShadowBorder"
                                    Background="Black" Opacity="0.2"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Margin="0,4,-4,0" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <TranslateTransform X="2" Y="2"/>
                                </Border.RenderTransform>
                            </Border>

                            <Border x:Name="RootBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="#3A3A3E"/>
                                                </ObjectAnimationUsingKeyFrames>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="BorderBrush">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="#80FFFFFF"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="#252526"/>
                                                </ObjectAnimationUsingKeyFrames>
                                                <DoubleAnimation Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Opacity" To="0.7" Duration="0"/>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>

                                <ContentPresenter x:Name="ContentPresenter"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Key="ShowDetailPanelStoryboard">
            <DoubleAnimation Storyboard.TargetName="PanelView"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CircleEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DashboardView"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.2"/>
        </Storyboard>

        <Storyboard x:Key="HideDetailPanelStoryboard">
            <DoubleAnimation Storyboard.TargetName="PanelView"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetName="DashboardView"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CircleEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
                <Button x:Name="filterbuttonall" Content="All" Width="120" Height="36" CornerRadius="18" Background="#333" BorderThickness="0" Click="filterbuttonall_Click" />
                <Button x:Name="filterbuttonenabled" Content="Enabled" Width="120" Height="36" CornerRadius="18" Background="#006400" BorderThickness="0" Click="filterbuttonenabled_Click"/>
                <Button x:Name="filterbuttondisabled" Content="Disabled" Width="120" Height="36" CornerRadius="18" Background="#8B4500" BorderThickness="0" Click="filterbuttondisabled_Click" />

                <AutoSuggestBox x:Name="SearchBox"
                                Width="300"
                                Height="36"
                                PlaceholderText="Search Extension..."
                                QueryIcon="Find"
                                TextChanged="SearchBox_TextChanged"
                                VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid x:Name="DashboardView" Visibility="Visible" Margin="10,0,10,10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="DashboardItems">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal" 
                                               HorizontalAlignment="Center" 
                                               MaximumRowsOrColumns="-1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        

                        <Button x:Name="preloadlistbutton" Click="preloadlist_Click" Tag="DISABLED" Style="{StaticResource ModernCardButtonStyle}">
                            <Grid Padding="15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Image Source="/functions/preloadlist.png" Width="32" Height="32" HorizontalAlignment="Left"/>
                                    <Border x:Name="preloadliststate_color" Background="Orange" CornerRadius="10" Padding="8,2" HorizontalAlignment="Right">
                                        <TextBlock x:Name="preloadliststate_text" Text="DISABLED" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="2">
                                    <TextBlock Text="Preload List" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                                    <TextBlock Text="Set files or programs to start automatically with GCM." FontSize="12" Foreground="#AAAAAA" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="losslessscalingbutton" Click="losslessscalingbutton_Click" Tag="DISABLED" Style="{StaticResource ModernCardButtonStyle}">
                            <Grid Padding="15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Image Source="/functions/lossless.png" Width="32" Height="32" HorizontalAlignment="Left"/>
                                    <Border x:Name="losslessscaling_color" Background="Orange" CornerRadius="10" Padding="8,2" HorizontalAlignment="Right">
                                        <TextBlock x:Name="losslessscaling_text" Text="DISABLED" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="2">
                                    <TextBlock Text="Lossless Scaling" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                                    <TextBlock Text="Trigger your scaling simply with GCM integration." FontSize="12" Foreground="#AAAAAA" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="gcmwallpaperbutton" Click="gcmwallpaperbutton_Click" Tag="DISABLED" Style="{StaticResource ModernCardButtonStyle}">
                            <Grid Padding="15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Image Source="/functions/TV.png" Width="32" Height="32" HorizontalAlignment="Left"/>
                                    <Border x:Name="gcmwallpaperstate_color" Background="Orange" CornerRadius="10" Padding="8,2" HorizontalAlignment="Right">
                                        <TextBlock x:Name="gcmwallpaperstate_text" Text="DISABLED" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="2">
                                    <TextBlock Text="Wallpaper" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                                    <TextBlock Text="Change your wallpaper inside GCM Mode!" FontSize="12" Foreground="#AAAAAA" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="joyxoffbutton" Click="joyxoffbutton_Click" Tag="DISABLED" Style="{StaticResource ModernCardButtonStyle}">
                            <Grid Padding="15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Image Source="/functions/joyxoff_logo.png" Width="32" Height="32" HorizontalAlignment="Left"/>
                                    <Border x:Name="joyxoffstate_color" Background="Orange" CornerRadius="10" Padding="8,2" HorizontalAlignment="Right">
                                        <TextBlock x:Name="joyxoffstate_text" Text="DISABLED" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="2">
                                    <TextBlock Text="JoyXOff" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                                    <TextBlock Text="Integrate your keyboard and mouse in one place." FontSize="12" Foreground="#AAAAAA" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="deckyloaderbutton" Click="deckyloaderbutton_Click" Tag="DISABLED" Style="{StaticResource ModernCardButtonStyle}">
                            <Grid Padding="15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Image Source="/functions/deckyloader.png" Width="32" Height="32" HorizontalAlignment="Left"/>
                                    <Border x:Name="deckyloaderstate_color" Background="Orange" CornerRadius="10" Padding="8,2" HorizontalAlignment="Right">
                                        <TextBlock x:Name="deckyloaderstate_text" Text="DISABLED" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="2">
                                    <TextBlock Text="Decky Loader" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                                    <TextBlock Text="Homebrew plugin system for Steam." FontSize="12" Foreground="#AAAAAA" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="preaudiobutton" Click="preaudiobutton_Click" Tag="DISABLED" Style="{StaticResource ModernCardButtonStyle}">
                            <Grid Padding="15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Image Source="/functions/speaker.png" Width="32" Height="32" HorizontalAlignment="Left"/>
                                    <Border x:Name="audiodevicestate_color" Background="Orange" CornerRadius="10" Padding="8,2" HorizontalAlignment="Right">
                                        <TextBlock x:Name="audiodevicestate_text" Text="DISABLED" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="2">
                                    <TextBlock Text="Audio Device" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                                    <TextBlock Text="Switch your audio devices automatically." FontSize="12" Foreground="#AAAAAA" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="displayfusionbutton" Click="displayfusionbutton_Click" Tag="DISABLED" Style="{StaticResource ModernCardButtonStyle}">
                            <Grid Padding="15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Image Source="/functions/displayfusion.png" Width="32" Height="32" HorizontalAlignment="Left"/>
                                    <Border x:Name="displayfusionstate_color" Background="Orange" CornerRadius="10" Padding="8,2" HorizontalAlignment="Right">
                                        <TextBlock x:Name="displayfusionstate_text" Text="DISABLED" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="2">
                                    <TextBlock Text="DisplayFusion" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                                    <TextBlock Text="Multiple Monitors Made Easy." FontSize="12" Foreground="#AAAAAA" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="startupvideobutton" Click="startupvideobutton_Click" Tag="DISABLED" Style="{StaticResource ModernCardButtonStyle}">
                            <Grid Padding="15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Image Source="/functions/Startup_Video.gif" Width="32" Height="32" HorizontalAlignment="Left"/>
                                    <Border x:Name="startupvideostate_color" Background="Orange" CornerRadius="10" Padding="8,2" HorizontalAlignment="Right">
                                        <TextBlock x:Name="startupvideostate_text" Text="DISABLED" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="2">
                                    <TextBlock Text="Startup Video" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                                    <TextBlock Text="Change your startup video when booting!" FontSize="12" Foreground="#AAAAAA" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="boilrbutton" Click="boilrbutton_Click" Tag="DISABLED" Style="{StaticResource ModernCardButtonStyle}">
                            <Grid Padding="15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Image Source="/functions/boilrlogo.png" Width="32" Height="32" HorizontalAlignment="Left"/>
                                    <Border x:Name="boilrstate_color" Background="Orange" CornerRadius="10" Padding="8,2" HorizontalAlignment="Right">
                                        <TextBlock x:Name="boilrstate_text" Text="DISABLED" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="2">
                                    <TextBlock Text="Sync Games" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                                    <TextBlock Text="Sync other Launcher games to Steam." FontSize="12" Foreground="#AAAAAA" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="PanelView"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  Visibility="Collapsed"
                  Opacity="0">

                <Grid.Background>
                    <SolidColorBrush Color="#181818" Opacity="0.98"/>
                </Grid.Background>

                <Grid Padding="30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <Button x:Name="CloseDetailButton" Click="CloseDetailPanel_Click" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" Padding="0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE72B;" FontSize="24" Foreground="White"/>
                                <TextBlock Text="Back to Extensions" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <BreadcrumbBar x:Name="BreadcrumbBar1" ItemClicked="BreadcrumbBar1_ItemClicked" FontSize="24" FontWeight="Bold" Margin="0,10,0,0"/>
                    </StackPanel>

                    <Grid x:Name="DetailContentGrid" Grid.Row="1">

                        <Grid x:Name="JoyxoffPanel" Visibility="Collapsed">
                            <ScrollViewer>
                                <Grid Padding="24" MaxWidth="800" HorizontalAlignment="Stretch">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <controls:SettingsCard Description="Enable JoyXoff in GCM mode" Header="ON/OFF">
                                            <ToggleSwitch x:Name="use_joyxoff" Toggled="use_joyxoff_Toggled" HorizontalAlignment="Right"/>
                                        </controls:SettingsCard>

                                        <controls:SettingsCard Header="INSTALLATION STATUS">
                                            <controls:SettingsCard.Description>
                                                <Border x:Name="border_install_state_joyxoff" Background="Green" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                                                    <TextBlock x:Name="text_install_state_joyxoff" Text="INSTALLED" Foreground="White" FontWeight="Bold"/>
                                                </Border>
                                            </controls:SettingsCard.Description>
                                            <Button x:Name="button_install_joyxoff" Content="DOWNLOAD" Click="button_install_joyxoff_Click"/>
                                        </controls:SettingsCard>

                                        <TextBlock Text="Documentation" FontSize="18" FontWeight="SemiBold" Margin="0,20,0,10"/>
                                        <muxc:InfoBar IsOpen="True" Severity="Warning" Title="Windows Only" Message="Could collide in GCM mode" Margin="0,0,0,10"/>
                                        <controls:SettingsCard Header="Installation instructions" Description="Please extract all files into a folder and run the executable inside. Then, return to GCM."/>
                                        <controls:SettingsCard Header="Official Website">
                                            <controls:SettingsCard.Description>
                                                <HyperlinkButton Content="Learn more about JoyXoff" NavigateUri="https://wiki.joyxoff.com/wiki/Main_Page"/>
                                            </controls:SettingsCard.Description>
                                            <HyperlinkButton Content="Link to Website" NavigateUri="https://joyxoff.com/en/"/>
                                        </controls:SettingsCard>
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </Grid>

                        <Grid x:Name="preloadlist" Visibility="Collapsed">
                            <ScrollViewer>
                                <Grid Padding="24" MaxWidth="800" HorizontalAlignment="Stretch">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <controls:SettingsCard Description="Enable Preload List in GCM mode" Header="ON/OFF">
                                            <ToggleSwitch x:Name="use_preloadlist" Toggled="use_preloadlist_Toggled" HorizontalAlignment="Right"/>
                                        </controls:SettingsCard>
                                        <controls:SettingsCard Header="INSTALLATION STATUS">
                                            <controls:SettingsCard.Description>
                                                <Border x:Name="border_install_state_preloadlist" Background="Green" CornerRadius="4" Padding="8,4">
                                                    <TextBlock x:Name="text_install_state_preloadlist" Text="INSTALLED" Foreground="White" FontWeight="Bold"/>
                                                </Border>
                                            </controls:SettingsCard.Description>
                                        </controls:SettingsCard>
                                        <controls:SettingsCard Header="Preload List Creation" Description="Use button to create/open .txt file.">
                                            <StackPanel Spacing="10">
                                                <Button x:Name="btn_create_or_open_preloadlist" Content="Create / Open list" Click="btn_create_or_open_preloadlist_Click" HorizontalAlignment="Stretch"/>
                                                <TextBox x:Name="preloadlist_path" Header="Path" IsEnabled="False" TextChanged="preloadlist_path_TextChanged"/>
                                            </StackPanel>
                                        </controls:SettingsCard>
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </Grid>

                        <Grid x:Name="preaudio" Visibility="Collapsed">
                            <ScrollViewer>
                                <Grid Padding="24" MaxWidth="800" HorizontalAlignment="Stretch">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <controls:SettingsCard Description="Enable Audio Selector" Header="ON/OFF">
                                            <ToggleSwitch x:Name="use_preaudio" Toggled="use_preaudio_Toggled" HorizontalAlignment="Right"/>
                                        </controls:SettingsCard>
                                        <controls:SettingsCard Header="INSTALLATION STATUS">
                                            <controls:SettingsCard.Description>
                                                <Border x:Name="border_install_state_preaudio" Background="Green" CornerRadius="4" Padding="8,4">
                                                    <TextBlock x:Name="text_install_state_preaudio" Text="INSTALLED" Foreground="White" FontWeight="Bold"/>
                                                </Border>
                                            </controls:SettingsCard.Description>
                                        </controls:SettingsCard>
                                        <controls:SettingsCard Header="Start Audio Device">
                                            <ComboBox x:Name="preaudio_start" SelectionChanged="preaudio_start_SelectionChanged" HorizontalAlignment="Stretch" MinWidth="200"/>
                                        </controls:SettingsCard>
                                        <controls:SettingsCard Header="End Audio Device">
                                            <ComboBox x:Name="preaudio_end" SelectionChanged="preaudio_end_SelectionChanged" HorizontalAlignment="Stretch" MinWidth="200"/>
                                        </controls:SettingsCard>
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </Grid>

                        <Grid x:Name="deckyloader" Visibility="Collapsed">
                            <ScrollViewer>
                                <Grid Padding="24" MaxWidth="800" HorizontalAlignment="Stretch">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <controls:SettingsCard Description="Enable Decky Loader" Header="ON/OFF">
                                            <ToggleSwitch x:Name="use_decky_loader" Toggled="use_decky_loader_Toggled_1" HorizontalAlignment="Right"/>
                                        </controls:SettingsCard>
                                        <controls:SettingsCard Header="INSTALLATION STATUS">
                                            <controls:SettingsCard.Description>
                                                <Border x:Name="border_install_state_decky_loader" Background="Green" CornerRadius="4" Padding="8,4">
                                                    <TextBlock x:Name="text_install_state_decky_loader" Text="INSTALLED" Foreground="White" FontWeight="Bold"/>
                                                </Border>
                                            </controls:SettingsCard.Description>
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Button x:Name="button_install_decky_loader" Content="Install" Click="button_install_decky_loader_Click"/>
                                                <Button x:Name="button_uninstall_decky_loader" Content="Uninstall" Click="button_uninstall_decky_loader_Click"/>
                                            </StackPanel>
                                        </controls:SettingsCard>
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </Grid>

                        <Grid x:Name="startupvideo" Visibility="Collapsed">
                            <ScrollViewer>
                                <Grid Padding="24" MaxWidth="800" HorizontalAlignment="Stretch">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <controls:SettingsCard Description="Enable Startup Video" Header="ON/OFF">
                                            <ToggleSwitch x:Name="use_startup_video" Toggled="use_startup_video_Toggled" HorizontalAlignment="Right"/>
                                        </controls:SettingsCard>
                                        <controls:SettingsCard Header="INSTALLATION STATUS">
                                            <controls:SettingsCard.Description>
                                                <Border x:Name="border_install_state_Startup_Video" Background="Green" CornerRadius="4" Padding="8,4">
                                                    <TextBlock x:Name="text_install_state_Startup_Video" Text="INSTALLED" Foreground="White" FontWeight="Bold"/>
                                                </Border>
                                            </controls:SettingsCard.Description>
                                        </controls:SettingsCard>
                                        <controls:SettingsCard Header="Video Path">
                                            <StackPanel Spacing="10">
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <Button x:Name="pichstartupvideopath" Content="Select File" Click="pichstartupvideopath_Click" Style="{StaticResource AccentButtonStyle}"/>
                                                    <Button x:Name="Resetstartupvideopath" Content="Reset" Click="Resetstartupvideopath_Click"/>
                                                </StackPanel>
                                                <TextBlock x:Name="textbox_select_startupvideo_path" Visibility="Collapsed"/>
                                                <TextBox x:Name="textbox_startupvideo_path" IsReadOnly="True" PlaceholderText="Path" TextChanged="textbox_startupvideo_path_TextChanged"/>
                                            </StackPanel>
                                        </controls:SettingsCard>
                                        <controls:SettingsCard Header="Steam Integration" Description="Replaces default Steam intro (WebM only)">
                                            <StackPanel Spacing="10">
                                                <CheckBox x:Name="UseSteamStartupVideo" Content="Use with Steam" Checked="UseSteamStartupVideoCheckBox_Checked" Unchecked="UseSteamStartupVideoCheckBox_Unchecked"/>
                                                <Button x:Name="Injectstartupvideo_button" Content="Inject Video" Click="Injectstartupvideo_button_Click" Style="{StaticResource AccentButtonStyle}"/>
                                                <ProgressBar x:Name="Injectstartupvideo_ProgressBar" Visibility="Collapsed" Maximum="100"/>
                                                <TextBlock x:Name="Injectstartupvideo_Text" Visibility="Collapsed"/>
                                            </StackPanel>
                                        </controls:SettingsCard>
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </Grid>

                        <Grid x:Name="displayfusion" Visibility="Collapsed">
                            <ScrollViewer>
                                <Grid Padding="24" MaxWidth="800" HorizontalAlignment="Stretch">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <controls:SettingsCard Description="Enable DisplayFusion" Header="ON/OFF">
                                            <ToggleSwitch x:Name="use_displayfusion" Toggled="use_displayfusion_Toggled" HorizontalAlignment="Right"/>
                                        </controls:SettingsCard>
                                        <controls:SettingsCard Header="INSTALLATION STATUS">
                                            <controls:SettingsCard.Description>
                                                <Border x:Name="border_install_state_displayfusion" Background="Green" CornerRadius="4" Padding="8,4">
                                                    <TextBlock x:Name="text_install_state_displayfusion" Text="INSTALLED" Foreground="White" FontWeight="Bold"/>
                                                </Border>
                                            </controls:SettingsCard.Description>
                                            <Button x:Name="button_install_displayfusion" Content="DOWNLOAD" Click="button_install_displayfusion_Click_2"/>
                                        </controls:SettingsCard>
                                        <controls:SettingsCard Header="Configs">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBox x:Name="displayfusion_start" Header="Start Config" PlaceholderText="START" TextChanged="displayfusion_start_TextChanged"/>
                                                <TextBox x:Name="displayfusion_end" Header="End Config" PlaceholderText="END" TextChanged="displayfusion_end_TextChanged"/>
                                            </StackPanel>
                                        </controls:SettingsCard>
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </Grid>

                        <Grid x:Name="gcmwallpaper" Visibility="Collapsed">

                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

                                <StackPanel Padding="24" MaxWidth="950" HorizontalAlignment="Stretch" Spacing="8">

                                    <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>

                                    <controls:SettingsCard Description="Enable Task Manager Wallpaper" Header="ON/OFF">
                                        <ToggleSwitch x:Name="use_wallpaper" Toggled="use_wallpaper_Toggled" HorizontalAlignment="Right"/>
                                    </controls:SettingsCard>

                                    <controls:SettingsCard Header="INSTALLATION STATUS">
                                        <controls:SettingsCard.Description>
                                            <Border x:Name="border_install_state_wallpaper" Background="Green" CornerRadius="4" Padding="8,4">
                                                <TextBlock x:Name="text_install_state_wallpaper" Text="INSTALLED" Foreground="White" FontWeight="Bold"/>
                                            </Border>
                                        </controls:SettingsCard.Description>
                                    </controls:SettingsCard>

                                    <controls:SettingsCard Header="Current Wallpaper Path">
                                        <TextBox x:Name="wallpaper_path" Header="Path" PlaceholderText="Path" TextChanged="wallpaper_path_TextChanged" Width="450"/>
                                    </controls:SettingsCard>

                                    <TextBlock Text="Online Search (Wallhaven)" FontSize="18" FontWeight="SemiBold" Margin="0,20,0,10"/>

                                    <controls:SettingsCard Header="Search Wallpaper" Description="Find high quality wallpapers">
                                        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" VerticalAlignment="Center">

                                            <TextBox x:Name="WallpaperSearchBox" 
                                                     PlaceholderText="Search..." 
                                                     Width="180" 
                                                     KeyDown="WallpaperSearchBox_KeyDown" 
                                                     VerticalAlignment="Center"/>

                                            <ComboBox x:Name="WallpaperResolutionCombo" SelectedIndex="0" VerticalAlignment="Center" Width="120">
                                                <ComboBoxItem Content="Any Res" Tag=""/>
                                                <ComboBoxItem Content="1080p" Tag="1920x1080"/>
                                                <ComboBoxItem Content="2K" Tag="2560x1440"/>
                                                <ComboBoxItem Content="4K" Tag="3840x2160"/>
                                                <ComboBoxItem Content="Ultrawide" Tag="3440x1440"/>
                                            </ComboBox>

                                            <Button x:Name="BtnSearchWallpaper" 
                                                    Content="Search" 
                                                    Click="BtnSearchWallpaper_Click" 
                                                    Style="{StaticResource AccentButtonStyle}" 
                                                    VerticalAlignment="Center"/>

                                            <Border Width="1" Height="20" Background="#33FFFFFF" Margin="5,0"/>

                                            <Button x:Name="BtnPrevPage" Content="&lt;" Click="BtnPrevPage_Click" IsEnabled="False" ToolTipService.ToolTip="Previous Page"/>
                                            <TextBlock x:Name="TxtPageNumber" Text="Page 1" VerticalAlignment="Center" FontWeight="SemiBold" Margin="5,0"/>
                                            <Button x:Name="BtnNextPage" Content="&gt;" Click="BtnNextPage_Click" IsEnabled="False" ToolTipService.ToolTip="Next Page"/>

                                        </StackPanel>
                                    </controls:SettingsCard>

                                    <ProgressBar x:Name="WallpaperLoadingBar" IsIndeterminate="True" Visibility="Collapsed" HorizontalAlignment="Stretch" Margin="0,10,0,10"/>

                                    <GridView x:Name="WallpaperResultsGrid" 
                                              SelectionMode="None"
                                              IsItemClickEnabled="True"
                                              ItemClick="WallpaperResultsGrid_ItemClick"
                                              ScrollViewer.VerticalScrollMode="Disabled"
                                              ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                              HorizontalAlignment="Stretch"
                                              Margin="0,10,0,0">

                                        <GridView.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <ItemsWrapGrid Orientation="Horizontal" HorizontalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </GridView.ItemsPanel>

                                        <GridView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Width="280" Height="158" Margin="8" CornerRadius="8" Background="#222" BorderBrush="#33FFFFFF" BorderThickness="1">
                                                    <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                                    <Grid VerticalAlignment="Bottom" Height="50">
                                                        <Grid.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="Transparent" Offset="0"/>
                                                                <GradientStop Color="#D9000000" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Grid.Background>
                                                    </Grid>

                                                    <Border Background="#99000000" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,8,8" CornerRadius="4" Padding="6,2" BorderBrush="#33FFFFFF" BorderThickness="1">
                                                        <TextBlock Text="{Binding Resolution}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                    </Border>

                                                    <TextBlock Text="Click to Apply" Foreground="#CCCCCC" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="10,0,0,8" FontSize="11" FontStyle="Italic"/>
                                                </Grid>
                                            </DataTemplate>
                                        </GridView.ItemTemplate>
                                    </GridView>

                                    <Grid Height="40"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <Grid x:Name="lossless" Visibility="Collapsed">
                            <ScrollViewer>
                                <Grid Padding="24" MaxWidth="800" HorizontalAlignment="Stretch">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <controls:SettingsCard Description="Enable integration" Header="ON/OFF">
                                            <ToggleSwitch x:Name="use_lossless" Toggled="use_lossless_Toggled" HorizontalAlignment="Right"/>
                                        </controls:SettingsCard>
                                        <controls:SettingsCard Header="INSTALLATION STATUS">
                                            <controls:SettingsCard.Description>
                                                <Border x:Name="border_install_state_lossless" Background="Green" CornerRadius="4" Padding="8,4">
                                                    <TextBlock x:Name="text_install_state_lossless" Text="INSTALLED" Foreground="White" FontWeight="Bold"/>
                                                </Border>
                                            </controls:SettingsCard.Description>
                                        </controls:SettingsCard>
                                        <controls:SettingsCard Header="Exe Path">
                                            <TextBox x:Name="lossless_path" Header="Path" PlaceholderText="Path" TextChanged="lossless_path_TextChanged" Width="400"/>
                                        </controls:SettingsCard>
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </Grid>

                        <Grid x:Name="boilr" Visibility="Collapsed">
                            <ScrollViewer>
                                <Grid Padding="24" MaxWidth="800" HorizontalAlignment="Stretch">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <controls:SettingsCard Description="Enable Auto Game Sync" Header="ON/OFF">
                                            <ToggleSwitch x:Name="use_boilr" Toggled="use_boilr_Toggled" HorizontalAlignment="Right"/>
                                        </controls:SettingsCard>

                                        <controls:SettingsCard Header="Download BoilR">
                                            <StackPanel Spacing="10">
                                                <TextBlock Text="Download latest version from GitHub" Foreground="Gray"/>
                                                <Button x:Name="btnDownloadBoilr" Content="Download" Click="btnDownloadBoilr_Click" Background="Green"/>
                                                <TextBlock x:Name="txtDownloadStatus" Foreground="Green"/>
                                            </StackPanel>
                                        </controls:SettingsCard>

                                        <controls:SettingsCard Header="INSTALLATION STATUS">
                                            <controls:SettingsCard.Description>
                                                <Border x:Name="border_install_state_boilr" Background="Green" CornerRadius="4" Padding="8,4">
                                                    <TextBlock x:Name="text_install_state_boilr" Text="INSTALLED" Foreground="White" FontWeight="Bold"/>
                                                </Border>
                                            </controls:SettingsCard.Description>
                                        </controls:SettingsCard>

                                        <controls:SettingsCard x:Name="boilr_api_field" Header="API KEY" Description="SteamGridDB API Key">
                                            <StackPanel Spacing="10">
                                                <Button x:Name="btn_create_or_open_boilr" Content="Get API Key" Click="btn_create_or_open_boilr_Click" HorizontalAlignment="Stretch"/>
                                                <TextBox x:Name="boilr_path" PlaceholderText="API KEY" TextChanged="boilr_path_TextChanged" Width="400"/>
                                            </StackPanel>
                                        </controls:SettingsCard>

                                        <controls:SettingsCard x:Name="boilr_launcher" Header="Launcher Integration">
                                            <StackPanel Spacing="8">
                                                <Grid>
                                                    <TextBlock Text="Amazon" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="-60"/>
                                                    <ToggleSwitch x:Name="Switch_Amazon" Toggled="Switch_Amazon_Toggled" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <Grid>
                                                    <TextBlock Text="Epic" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="-60"/>
                                                    <ToggleSwitch x:Name="Switch_Epic" Toggled="Switch_Epic_Toggled" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <Grid>
                                                    <TextBlock Text="GOG" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="-60"/>
                                                    <ToggleSwitch x:Name="Switch_GOG" Toggled="Switch_GOG_Toggled" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <Grid>
                                                    <TextBlock Text="Itch.io" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="-60"/>
                                                    <ToggleSwitch x:Name="Switch_Itch" Toggled="Switch_Itch_Toggled" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <Grid>
                                                    <TextBlock Text="Origin" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="-60"/>
                                                    <ToggleSwitch x:Name="Switch_Origin" Toggled="Switch_Origin_Toggled" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <Grid>
                                                    <TextBlock Text="Ubisoft" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="-60"/>
                                                    <ToggleSwitch x:Name="Switch_Uplay" Toggled="Switch_Uplay_Toggled" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <Grid>
                                                    <TextBlock Text="Playnite" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="-60"/>
                                                    <ToggleSwitch x:Name="Switch_Playnite" Toggled="Switch_Playnite_Toggled" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <Grid>
                                                    <TextBlock Text="Xbox" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="-60"/>
                                                    <ToggleSwitch x:Name="Switch_GamePass" Toggled="Switch_GamePass_Toggled" HorizontalAlignment="Right"/>
                                                </Grid>
                                            </StackPanel>
                                        </controls:SettingsCard>
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </Grid>

                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>