<Page
    x:Class="GAMINGCONSOLEMODE.startup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="using:Microsoft.UI.Xaml.Controls">
    <Page.Background>
        <LinearGradientBrush StartPoint="1,0" EndPoint="0.5,0.5">
            <GradientStop Color="#002A2F3D" Offset="0.0"/>
            <GradientStop Color="#4094B8DE" Offset="0.3"/>
            <GradientStop Color="#002A2F3D" Offset="1.0"/>
        </LinearGradientBrush>
    </Page.Background>

    <Page.Resources>
        <Style TargetType="Button" x:Key="DashboardButtonStyle">
            <Setter Property="Width" Value="220"/>
            <Setter Property="Height" Value="200"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
            
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,1" EndPoint="0.5,0.5">
                        <GradientStop Color="#FF2D2D30" Offset="0.2"/>
                        <GradientStop Color="#FF3E3E42" Offset="0.6"/>
                        <!-- Wieder wegblendend -->
                    </LinearGradientBrush>


                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                CornerRadius="10"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                RenderTransformOrigin="0.5,0.5">

                            <Border.RenderTransform>
                                <ScaleTransform x:Name="ButtonScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                             Storyboard.TargetProperty="ScaleX"
                                             To="1.05" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                             Storyboard.TargetProperty="ScaleY"
                                             To="1.05" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                             Storyboard.TargetProperty="ScaleX"
                                             To="0.98" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                             Storyboard.TargetProperty="ScaleY"
                                             To="0.98" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>





        <!-- Animations-Storyboards -->
        <Storyboard x:Key="ShowDetailPanelStoryboard">
            <DoubleAnimation Storyboard.TargetName="PanelView"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="DashboardView"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.3"/>
        </Storyboard>

        <Storyboard x:Key="HideDetailPanelStoryboard">
            <DoubleAnimation Storyboard.TargetName="PanelView"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="DashboardView"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3"/>
        </Storyboard>
    </Page.Resources>

    <Grid Margin="0">
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" >

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,20" Spacing="20" VerticalAlignment="Top">
                <Button x:Name="filterbuttonall" Content="All" Width="100" Height="40"  Background="Gray" Click="filterbuttonall_Click" />
                <Button x:Name="filterbuttonenabled" Content="Enabled" Width="100" Height="40" Background="Green" Click="filterbuttonenabled_Click"/>
                <Button x:Name="filterbuttondisabled" Content="Disabled" Width="100" Height="40" Background="Orange"  Click="filterbuttondisabled_Click" />
                <AutoSuggestBox Grid.Row="0"
                                Width="400"
                                Height="40"
                                    Margin="20"          
                                PlaceholderText="Search for Extension"
                                Background="DimGray"
                                BorderBrush="#FFCCCCCC"
                                BorderThickness="0"
                                CornerRadius="5"
                                Padding="0"
                                        Name="SearchBox"
                                        TextChanged="SearchBox_TextChanged"

                                FontSize="14"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"/>
            </StackPanel>
        </Grid>
       

        <Grid Grid.Row="2">


            <Grid x:Name="DashboardView" Visibility="Visible" CornerRadius="20" Margin="10">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="1,0" EndPoint="0.5,0.5">
                        <GradientStop Color="Transparent" Offset="0.0"/>
                        <!-- Unsichtbar -->
                    </LinearGradientBrush>


    

                </Grid.Background>
                <ScrollViewer  VerticalScrollBarVisibility="Visible">
                    <ItemsControl  x:Name="DashboardItems">
                        <ItemsControl.ItemsPanel>
                           
                            <ItemsPanelTemplate>
                                <VariableSizedWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4" 
                                                       HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.Resources>
                            <Style TargetType="Button" BasedOn="{StaticResource DashboardButtonStyle}" />
                        </ItemsControl.Resources>

                        <Button x:Name="cssloaderbutton" Click="cssloader_Click"  Tag="DISABLED" HorizontalContentAlignment="Left" BorderThickness="2">
                            <StackPanel Tag="DISABLED" HorizontalAlignment="Left">
                                <Image Source="/Assets/steambp.png" Width="30" Height="70" Stretch="Uniform" HorizontalAlignment="Left" Margin="-10,-20,0,0"/>
                                <TextBlock Text="CSS Loader" FontSize="14" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Left" TextAlignment="Left" Margin="-10,0,0,0"/>
                                <TextBlock Text="A styling engine for Steam on Windows and Linux." Width="150" TextWrapping="Wrap" FontSize="12" FontWeight="Normal" Foreground="White" HorizontalAlignment="Left" TextAlignment="Left" Margin="-10,5,0,0"/>
                                <Grid HorizontalAlignment="Right" Margin="0,20,-10,0">

                                    <Border x:Name="cssloaderstate_color" Background="Orange" Padding="5,2" CornerRadius="6" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                                        <TextBlock x:Name="cssloaderstate_text" Text="DISABLED" Foreground="White" FontSize="12" HorizontalAlignment="Left"/>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Button>

                        <Button x:Name="preloadlistbutton" Click="preloadlist_Click"  Tag="DISABLED" HorizontalContentAlignment="Left" BorderThickness="2">
                            <StackPanel Tag="DISABLED">
                                <Image Source="/functions/preloadlist.png" Width="40" Height="70" Stretch="Uniform" HorizontalAlignment="Left" Margin="-10,-20,0,0"/>
                                <TextBlock Text="Preload List" FontSize="14" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Left" TextAlignment="Left" Margin="-10,0,0,0"/>
                                <TextBlock Text="Set files or programs to start with GCM." Width="150" TextWrapping="Wrap" FontSize="12" FontWeight="Normal" Foreground="White" HorizontalAlignment="Left" TextAlignment="Left" Margin="-10,5,0,0"/>
                                <Grid HorizontalAlignment="Right" Margin="0,20,-10,0">

                                    <Border x:Name="preloadliststate_color" Background="Orange" Padding="5,2" CornerRadius="6" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                                        <TextBlock x:Name="preloadliststate_text" Text="DISABLED" Foreground="White" FontSize="12"/>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Button>

                        <Button x:Name="gcmwallpaperbutton" Click="gcmwallpaperbutton_Click"  Tag="DISABLED" HorizontalContentAlignment="Left" BorderThickness="2">
                            <StackPanel x:Name="gcmwallpaperpanel" Tag="DISABLED" >
                                <Image Source="/functions/TV.png" Width="40" Height="70" Stretch="Uniform" HorizontalAlignment="Left" Margin="-10,-20,0,0"/>
                                <TextBlock Text="Wallpaper" FontSize="14" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Left" TextAlignment="Left" Margin="-10,0,0,0"/>
                                <TextBlock Text="Change your wallpaper inside GCM Mode!" Width="150" TextWrapping="Wrap" FontSize="12" FontWeight="Normal" Foreground="White" HorizontalAlignment="Left" TextAlignment="Left" Margin="-10,5,0,0"/>
                                <Grid HorizontalAlignment="Right" Margin="0,20,-10,0">
                                    <Border x:Name="gcmwallpaperstate_color" Background="Orange" Padding="5,2" CornerRadius="6" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                                        <TextBlock x:Name="gcmwallpaperstate_text" Text="DISABLED" Foreground="White" FontSize="12"/>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Button>

                        <Button x:Name="joyxoffbutton" Click="joyxoffbutton_Click"  Tag="DISABLED" HorizontalContentAlignment="Left" BorderThickness="2">
                            <StackPanel Tag="DISABLED" >
                                <Image Source="/functions/joyxoff_logo.png" Width="40" Height="70" Stretch="Uniform" HorizontalAlignment="Left" Margin="-10,-20,0,0"/>
                                <TextBlock Text="JoyXOff" FontSize="14" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Left" TextAlignment="Left" Margin="-10,0,0,0"/>
                                <TextBlock Text="Integrate your keyboard and mouse in one place." Width="150" TextWrapping="Wrap" FontSize="12" FontWeight="Normal" Foreground="White" HorizontalAlignment="Left" TextAlignment="Left" Margin="-10,5,0,0"/>
                                <Grid HorizontalAlignment="Right" Margin="0,20,-10,0">

                                    <Border x:Name="joyxoffstate_color" Background="Orange" Padding="5,2" CornerRadius="6" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                                        <TextBlock x:Name="joyxoffstate_text" Text="DISABLED" Foreground="White" FontSize="12"/>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Button>

                        <Button x:Name="deckyloaderbutton" Click="deckyloaderbutton_Click"  Tag="DISABLED" HorizontalContentAlignment="Left" BorderThickness="2">
                            <StackPanel Tag="DISABLED">
                                <Image Source="/functions/deckyloader.png" Width="35" Height="70" Stretch="Uniform" HorizontalAlignment="Left" Margin="-10,-20,0,0"/>
                                <TextBlock Text="Decky Loader" FontSize="14" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Left" TextAlignment="Left" Margin="-10,0,0,0"/>
                                <TextBlock Text="Homebrew plugin system for Steam." Width="150" TextWrapping="Wrap" FontSize="12" FontWeight="Normal" Foreground="White" HorizontalAlignment="Left" TextAlignment="Left" Margin="-10,5,0,0"/>
                                <Grid HorizontalAlignment="Right" Margin="0,20,-10,0">

                                    <Border x:Name="deckyloaderstate_color" Background="Orange" Padding="5,2" CornerRadius="6" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                                        <TextBlock x:Name="deckyloaderstate_text" Text="DISABLED" Foreground="White" FontSize="12"/>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Button>

                        <Button x:Name="preaudiobutton" Click="preaudiobutton_Click"  Tag="DISABLED" HorizontalContentAlignment="Left" BorderThickness="2">
                            <StackPanel Tag="DISABLED">
                                <Image Source="/functions/speaker.png" Width="40" Height="70" Stretch="Uniform" HorizontalAlignment="Left" Margin="-10,-20,0,0"/>
                                <TextBlock Text="Audio Device" FontSize="14" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Left" TextAlignment="Left" Margin="-10,0,0,0"/>
                                <TextBlock Text="Switch your audio devices for GCM." Width="150" TextWrapping="Wrap" FontSize="12" FontWeight="Normal" Foreground="White" HorizontalAlignment="Left" TextAlignment="Left" Margin="-10,5,0,0"/>
                                <Grid HorizontalAlignment="Right" Margin="0,20,-10,0">

                                    <Border x:Name="audiodevicestate_color" Background="Orange" Padding="5,2" CornerRadius="6" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                                        <TextBlock x:Name="audiodevicestate_text" Text="DISABLED" Foreground="White" FontSize="12"/>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Button>

                        <Button x:Name="displayfusionbutton" Click="displayfusionbutton_Click"  Tag="DISABLED" HorizontalContentAlignment="Left" BorderThickness="2">
                            <StackPanel Tag="DISABLED">
                                <Image Source="/functions/displayfusion.png" Width="40" Height="70" Stretch="Uniform" HorizontalAlignment="Left" Margin="-10,-20,0,0"/>
                                <TextBlock Text="DisplayFusion" FontSize="14" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Left" TextAlignment="Left" Margin="-10,0,0,0"/>
                                <TextBlock Text="Multiple Monitors Made Easy." Width="150" TextWrapping="Wrap" FontSize="12" FontWeight="Normal" Foreground="White" HorizontalAlignment="Left" TextAlignment="Left" Margin="-10,5,0,0"/>
                                <Grid HorizontalAlignment="Right" Margin="0,20,-10,0">

                                    <Border x:Name="displayfusionstate_color" Background="Orange" Padding="5,2" CornerRadius="6" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                                        <TextBlock x:Name="displayfusionstate_text" Text="DISABLED" Foreground="White" FontSize="12"/>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Button>

                        <Button x:Name="startupvideobutton"  Click="startupvideobutton_Click"  Tag="DISABLED" HorizontalContentAlignment="Left" BorderThickness="2">
                            <StackPanel Tag="DISABLED">
                                <Image Source="/functions/Startup_Video.gif" Width="40" Height="70" Stretch="Uniform" HorizontalAlignment="Left" Margin="-10,-20,0,0"/>
                                <TextBlock Text="Startup Video" FontSize="14" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Left" TextAlignment="Left" Margin="-10,0,0,0"/>
                                <TextBlock Text="Change your startup video when booting into GCM!" Width="150" TextWrapping="Wrap" FontSize="12" FontWeight="Normal" Foreground="White" HorizontalAlignment="Left" TextAlignment="Left" Margin="-10,5,0,0"/>
                                <Grid HorizontalAlignment="Right" Margin="0,20,-10,0">
                                    <Border x:Name="startupvideostate_color" Background="Orange" Padding="5,2" CornerRadius="6" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                                        <TextBlock x:Name="startupvideostate_text" Text="DISABLED" Foreground="White" FontSize="12"/>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Button>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="PanelView"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  CornerRadius="15"
                  Margin="20"
                  Visibility="Collapsed"
                  Opacity="0">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="Transparent"  Offset="0.0" />
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid HorizontalAlignment="Stretch"  VerticalAlignment="Stretch"  >
                    <StackPanel>
                        <Grid RenderTransformOrigin="0,0.5" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20,5,0,45">
                            <Grid.RenderTransform>
                                <!-- 1.25 = 125 % of the default size -->
                                <ScaleTransform ScaleX="3" ScaleY="3"/>
                            </Grid.RenderTransform>
                            <BreadcrumbBar x:Name="BreadcrumbBar1" ItemClicked="BreadcrumbBar1_ItemClicked" FontSize="66"/>
                               
                        </Grid>
                            <Grid x:Name="DetailContentGrid">
                            <!-- Panels -->
                            <!--joyxoff-->
                            <Grid x:Name="JoyxoffPanel"
                                  Visibility="Collapsed"
                                  Background="Transparent"
                                  xmlns:controls="using:CommunityToolkit.WinUI.Controls"
                                  xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Visible"
                                              Grid.Row="0"
                                              Height="400">

                                    <Grid Padding="24">

                                        <StackPanel Spacing="4">

                                            <TextBlock Text="Settings" FontSize="14" FontWeight="SemiBold" Margin="0,8,36,0"/>


                                            <controls:SettingsCard Description="Enable JoyXoff in GCM mode"
                                              Header="ON/OFF" >
                                                <ToggleSwitch x:Name="use_joyxoff"
                                                              Toggled="use_joyxoff_Toggled"
                                                              HorizontalAlignment="Center"/>
                                            </controls:SettingsCard>


                                            <controls:SettingsCard Header="INSTALLATION PANEL">
                                                <controls:SettingsCard.Description>
                                                    <Border x:Name="border_install_state_joyxoff"
                                                            Grid.Column="1"
                                                            Background="Green"
                                                            CornerRadius="8"
                                                            Padding="10,5"
                                                            Margin="0,10,0,0"
                                                            HorizontalAlignment="Left">
                                                        <TextBlock x:Name="text_install_state_joyxoff"
                                                                   Text="INSTALLED"
                                                                   Foreground="White"
                                                                   FontSize="13"
                                                                   FontWeight="Bold"
                                                                   TextAlignment="Center"/>
                                                    </Border>
                                                </controls:SettingsCard.Description>

                                                <StackPanel VerticalAlignment="Center">
                                                    <Button x:Name="button_install_joyxoff" Content="DOWNLOAD" Margin="10" Width="150" Click="button_install_joyxoff_Click"/>
                                                </StackPanel>
                                            </controls:SettingsCard>


                                            <TextBlock Text="Documentary" FontSize="14" FontWeight="SemiBold" Margin="0,8,24,0"/>

                                            <muxc:InfoBar IsOpen="True"
                                                          Severity="Warning"
                                                          Title="Windows Only"
                                                          Message="Could collide in GCM mode"
                                                          HorizontalAlignment="Stretch"
                                                          Margin="0,0,0,0"/>

                                            <controls:SettingsCard  Description="Please extract all files into a folder and run the executable inside. Then, return to GCM."
                                                                    Header="Installation instructions" >
                                                <controls:SettingsCard.Resources>
                                                    <x:Double x:Key="SettingsCardWrapThreshold">800</x:Double>
                                                    <x:Double x:Key="SettingsCardWrapNoIconThreshold">600</x:Double>
                                                </controls:SettingsCard.Resources>
                                            </controls:SettingsCard>


                                            <controls:SettingsCard Header="Offical Website">
                                                <controls:SettingsCard.Description>
                                                    <HyperlinkButton Content="Learn more about JoyXoff" NavigateUri="https://wiki.joyxoff.com/wiki/Main_Page"/>
                                                </controls:SettingsCard.Description>
                                                <HyperlinkButton Content="Link to Website" NavigateUri="https://joyxoff.com/en/"/>
                                            </controls:SettingsCard>

                                            <controls:SettingsCard x:Name="AboutJoyXoff"
                                                                   Header="About">
                                                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top">
                                                    <TextBlock Text="Integrate your keyboard and mouse in one place" Margin="0,0,0,20" FontWeight="SemiBold" TextAlignment="Right"/>
                                                    <TextBlock Text="JoyXoff is a free and lightweight Xbox controller mapper which allows you to simulate mouse " TextAlignment="Right"/>
                                                    <TextBlock Text="and keyboard events, media functions and create process profiles individually," TextAlignment="Right"/>
                                                    <TextBlock Text="as well as offer the ability to turn off Xbox 360 wireless Controller." TextAlignment="Right"/>
                                                </StackPanel>
                                            </controls:SettingsCard>

                                        </StackPanel>

                                    </Grid>

                                </ScrollViewer>

                            </Grid>
                            <!--Preloadlist-->
                            <Grid x:Name="preloadlist" Visibility="Collapsed"
                                  xmlns:controls="using:CommunityToolkit.WinUI.Controls">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Visible"
                                              Grid.Row="0"
                                              Height="400">

                                    <Grid Padding="24">

                                        <StackPanel Spacing="4">

                                            <TextBlock Text="Settings" FontSize="14" FontWeight="SemiBold" Margin="0,8,36,0"/>


                                            <controls:SettingsCard Description="Enable Preload List in GCM mode"
                                              Header="ON/OFF" >
                                                <ToggleSwitch x:Name="use_preloadlist"
                                                              Toggled="use_preloadlist_Toggled"
                                                              HorizontalAlignment="Center"/>
                                            </controls:SettingsCard>


                                            <controls:SettingsCard Header="INSTALLATION PANEL">
                                                <controls:SettingsCard.Description>
                                                    <Border x:Name="border_install_state_preloadlist"
                                                            Grid.Column="1"
                                                            Background="Green"
                                                            CornerRadius="8"
                                                            Padding="10,5"
                                                            Margin="0,10,0,0"
                                                            HorizontalAlignment="Left">
                                                        <TextBlock x:Name="text_install_state_preloadlist"
                                                                   Text="INSTALLED"
                                                                   Foreground="White"
                                                                   FontSize="13"
                                                                   FontWeight="Bold"
                                                                   TextAlignment="Center"/>
                                                    </Border>
                                                </controls:SettingsCard.Description>
                                            </controls:SettingsCard>

                                            <controls:SettingsCard Header="Preload List Creation"
                                                                   Description="Please use the button to create a .txt file.">
                                                <StackPanel>
                                                    <Button x:Name="btn_create_or_open_preloadlist"
                                                        Content="Create list / Open list"
                                                        Width="250"
                                                        Height="40"
                                                        CornerRadius="5"
                                                        Click="btn_create_or_open_preloadlist_Click"
                                                        HorizontalAlignment="Stretch"/>
                                                    <TextBox x:Name="preloadlist_path"
                                                             Header="Preload List Path"
                                                             PlaceholderText="Path"
                                                             IsEnabled="False"
                                                             Width="500"
                                                             CornerRadius="5"
                                                             TextChanged="preloadlist_path_TextChanged"
                                                             Grid.Column="1"/>
                                                </StackPanel>
                                            </controls:SettingsCard>

                                            <TextBlock Text="Documentary" FontSize="14" FontWeight="SemiBold" Margin="0,8,24,0"/>

                                            <controls:SettingsCard  Description="List each program or file with a path WITHOUT quotation mark on a new line - Comments start with #"
                                                                    Header="Installation instructions" >
                                                <controls:SettingsCard.Resources>
                                                    <x:Double x:Key="SettingsCardWrapThreshold">800</x:Double>
                                                    <x:Double x:Key="SettingsCardWrapNoIconThreshold">600</x:Double>
                                                </controls:SettingsCard.Resources>
                                            </controls:SettingsCard>

                                            <controls:SettingsCard x:Name="AboutPreloadList"
                                                                   Header="About">
                                                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top">
                                                    <TextBlock Text="Automatically launch files when GCM Starts!" Margin="0,0,0,20" FontWeight="SemiBold" TextAlignment="Right"/>
                                                    <TextBlock Text="GCM will automatically launch all files listed in your Preload List at Startup." TextAlignment="Right"/>
                                                    <TextBlock Text="This can be useful for commonly used applications and files" TextAlignment="Right"/>
                                                    <TextBlock Text="helping you save time and avoid unnecessary hassle." TextAlignment="Right"/>
                                                </StackPanel>
                                            </controls:SettingsCard>

                                        </StackPanel>

                                    </Grid>

                                </ScrollViewer>

                            </Grid>
                            <!--Preaudio-->
                            <Grid x:Name="preaudio" Visibility="Collapsed"
                                  xmlns:controls="using:CommunityToolkit.WinUI.Controls">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Visible"
                                              Grid.Row="0"
                                              Height="400">

                                    <Grid Padding="24">

                                        <StackPanel Spacing="4">

                                            <TextBlock Text="Settings" FontSize="14" FontWeight="SemiBold" Margin="0,8,36,0"/>


                                            <controls:SettingsCard Description="Enable Audio Device Selector in GCM mode"
                                                  Header="ON/OFF" >
                                                <ToggleSwitch x:Name="use_preaudio"
                                                                  Toggled="use_preaudio_Toggled"
                                                                  HorizontalAlignment="Center"/>
                                            </controls:SettingsCard>


                                            <controls:SettingsCard Header="INSTALLATION PANEL">
                                                <controls:SettingsCard.Description>
                                                    <Border x:Name="border_install_state_preaudio"
                                                                    Grid.Column="1"
                                                                    Background="Green"
                                                                    CornerRadius="8"
                                                                    Padding="10,5"
                                                                    Margin="0,10,0,0"
                                                                    HorizontalAlignment="Left">
                                                        <TextBlock x:Name="text_install_state_preaudio"
                                                                Text="INSTALLED"
                                                                Foreground="White"
                                                                FontSize="13"
                                                                FontWeight="Bold"
                                                                TextAlignment="Center"/>
                                                    </Border>
                                                </controls:SettingsCard.Description>
                                            </controls:SettingsCard>



                                            <controls:SettingsCard Header="Audio device when GCM starts">
                                                <ComboBox x:Name="preaudio_start"
                                                          Width="500"
                                                          Margin="0,5,0,10"
                                                          SelectionChanged="preaudio_start_SelectionChanged"/>
                                            </controls:SettingsCard>

                                            <controls:SettingsCard Header="Audio device when GCM ends">
                                                <ComboBox x:Name="preaudio_end"
                                                          Width="500"
                                                          Margin="0,5,0,10"
                                                          SelectionChanged="preaudio_end_SelectionChanged"/>
                                            </controls:SettingsCard>

                                            <TextBlock Text="Documentary" FontSize="14" FontWeight="SemiBold" Margin="0,8,24,0"/>

                                            <controls:SettingsCard  Description="Please select your Audio Devices."
                                                                        Header="Installation instructions" >
                                                <controls:SettingsCard.Resources>
                                                    <x:Double x:Key="SettingsCardWrapThreshold">800</x:Double>
                                                    <x:Double x:Key="SettingsCardWrapNoIconThreshold">600</x:Double>
                                                </controls:SettingsCard.Resources>
                                            </controls:SettingsCard>

                                            <controls:SettingsCard x:Name="AboutAudio"
                                                                           Header="About">
                                                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top">
