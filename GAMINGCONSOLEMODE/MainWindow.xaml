<Window
    x:Class="GAMINGCONSOLEMODE.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:GAMINGCONSOLEMODE"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="XlineGame">

    <!-- Root Grid -->
    <Grid Background="#2a475e">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Topbar -->
            <RowDefinition Height="Auto" />
            <!-- CommandBar -->
            <RowDefinition Height="*" />
            <!-- NavigationView -->
        </Grid.RowDefinitions>

        <!-- Topbar -->
        <Grid Grid.Row="0" Background="#333" Height="120" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left Logo -->
            <Image Source="Assets/gcm_ui_logo.png" Height="100" Margin="25,5"/>
            
            <!-- Right Panel with Button and ToggleSwitch SIDE-BY-SIDE -->
            <StackPanel Grid.Column="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="10"
                Spacing="12">
                <Button x:Name="DiscordButton"
        Click="DiscordImageButton_Click"
        Background="Transparent"
        BorderBrush="Transparent"
        Padding="0"
        HorizontalAlignment="Stretch"
        Margin="0,0,20,0">

                    <Border Background="#22FFFFFF"
            CornerRadius="8"
            Padding="15"
                            
            MaxWidth="500">

                        <Grid ColumnSpacing="15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Image Grid.Column="0"
                   Source="ms-appx:///Assets/onboarding/discord.jpg" 
                   Width="48" 
                   Height="48"
                   VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Join us on Discord"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="White"/>
                                <TextBlock Text="Support, Suggestions, Updates &amp; Community"
                           Foreground="LightGray"
                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Button>

                <Button x:Name="patreonButton"
Click="patreonButton_Click"
Background="Transparent"
BorderBrush="Transparent"
Padding="0"
HorizontalAlignment="Stretch"
Margin="0,0,20,0">

                    <Border Background="#22FFFFFF"
    CornerRadius="8"
    Padding="15"
                    
    MaxWidth="500">

                        <Grid ColumnSpacing="15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Image Grid.Column="0"
           Source="ms-appx:///Assets/onboarding/patreon.png" 
           Width="48" 
           Height="48"
           VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Unlock premium feature"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="White"/>
                                <TextBlock Text="Shape the future of GCM"
                   Foreground="LightGray"
                   TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Button>


                <!-- ToggleSwitch next to Button -->
              


                <!-- START GCM Button mit mehrfarbigem Verlauf -->
                <Button x:Name="MenuButton"
        Content="START XlineGame"
        CornerRadius="10"
        BorderBrush="SlateGray"
        BorderThickness="2"
        Foreground="White"
        Padding="12,6"
        Click="TopbarButton_Click"
        Height="50"
        Width="200"
                        
                        >

                    <!-- Farbverlauf als Hintergrund -->
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF2D2D30" Offset="0.0"/>
                            <GradientStop Color="#FF3E3E42" Offset="1.0"/>
                            <!-- Turquoise -->
                        </LinearGradientBrush>
                    </Button.Background>

                    <!-- Hover- und Klickzust�nde -->
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Target="MenuButton.Opacity" Value="0.85"/>
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Target="MenuButton.Opacity" Value="0.6"/>
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                </Button>



            </StackPanel>
        </Grid>



        <!-- CommandBar at the top -->
        <!-- CommandBar for Update Status -->
        <CommandBar x:Name="UpdateBar"
            Grid.Row="1"
            Background="DarkOliveGreen"
            HorizontalAlignment="Stretch"
            OverflowButtonVisibility="Collapsed"
            Visibility="Collapsed">

            <CommandBar.PrimaryCommands>
                <!-- Progress display with text info -->
                <AppBarElementContainer>
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                        <ProgressBar x:Name="UpdateProgressBar"
                             Width="500"
                             Height="20"
                             Value="0"
                             IsIndeterminate="False"
                             ShowPaused="False"
                             ShowError="False"
                             Visibility="Collapsed"/>
                        <TextBlock x:Name="DownloadProgressText"
                           Foreground="White"
                           FontSize="12"
                           Visibility="Collapsed"
                           Margin="0,4,0,0"
                           Text="0 MB / 0 MB"/>
                    </StackPanel>
                </AppBarElementContainer>

                <!-- Update Info Text -->
                <AppBarElementContainer>
                    <TextBlock x:Name="UpdateBarText"
                       Text="Update Available"
                       Foreground="White"
                       FontSize="16"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Margin="10"/>
                </AppBarElementContainer>


                <!-- News Trigger Button -->
                <AppBarButton x:Name="newsButton"
Background="White"
Foreground="Green"
Visibility="Visible"
Icon="PostUpdate"
Label="News"
Click="newsButton_Click">
                    <AppBarButton.RenderTransform>
                        <ScaleTransform x:Name="newsButtonScale" ScaleX="1" ScaleY="1"/>
                    </AppBarButton.RenderTransform>
                </AppBarButton>
                
                <!-- Update Trigger Button -->
                <AppBarButton x:Name="UpdateButton"
              Background="White"
              Foreground="Green"
              Visibility="Visible"
              Icon="Download"
              Label="Update"
              Click="UpdateButton_Click">
                    <AppBarButton.RenderTransform>
                        <ScaleTransform x:Name="UpdateButtonScale" ScaleX="1" ScaleY="1"/>
                    </AppBarButton.RenderTransform>
                </AppBarButton>

               

                <!-- Install Trigger Button -->
                <AppBarButton x:Name="InstallUpdateButton"
                      Background="White"
                      Foreground="Green"
                      Visibility="Collapsed"
                      Icon="OpenFile"
                      Label="Install"
                      Click="InstallUpdateButton_Click"/>
            </CommandBar.PrimaryCommands>
        </CommandBar>

        <!-- NavigationView filling the remaining space -->
        <NavigationView Grid.Row="2"
                        x:Name="nvMain"
                        PaneDisplayMode="Left"
                        SelectionChanged="NavigationView_SelectionChanged"
                        Background="#2A2A2A"
                        IsBackEnabled="True">
            
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Onboarding" Icon="Placeholder" Tag="OnboardingPage" />
                <NavigationViewItem Content="Launcher" Icon="StopSlideShow" Tag="LauncherPage" />
                <NavigationViewItem Content="Extensions" Icon="List"  Tag="StartupPage" />
                <NavigationViewItem Content="Shortcuts" Icon="Add" Tag="shortcuts" />
                <NavigationViewItem Content="Task Manager" Icon="Pin"  Tag="TaskManagerPage" />
                <NavigationViewItem Content="Retro Games" Icon="Play" Tag="RetroGamesPage" />
                <NavigationViewItem Content="Handheld specific" Icon="SwitchApps" Tag="Handheld">
                    <NavigationViewItem.MenuItems>
                        <NavigationViewItem Content="Rog Ally" Icon="DockBottom" Tag="RogAllyPage" />
                    </NavigationViewItem.MenuItems>
                </NavigationViewItem>
                <NavigationViewItemSeparator />
                <NavigationViewItem Content="additional features" Icon="ViewAll" Tag="Handheld">
                    <NavigationViewItem.MenuItems>
                        <NavigationViewItem Content="Links" Icon="Link" Tag="LinksPage" />
                    </NavigationViewItem.MenuItems>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="contentFrame">
                <Frame.ContentTransitions>
                    <TransitionCollection>
                        <NavigationThemeTransition />
                    </TransitionCollection>
                </Frame.ContentTransitions>
            </Frame>
        </NavigationView>
    </Grid>
</Window>
