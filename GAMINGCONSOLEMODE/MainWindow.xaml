<Window
    x:Class="GAMINGCONSOLEMODE.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:GAMINGCONSOLEMODE"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="GAMINGCONSOLEMODE">

    <!-- Root Grid -->
    <Grid Background="#2a475e">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Topbar -->
            <RowDefinition Height="Auto" />
            <!-- CommandBar -->
            <RowDefinition Height="*" />
            <!-- NavigationView -->
        </Grid.RowDefinitions>

        <!-- Topbar -->
        <Grid Grid.Row="0" Background="#333" Height="120" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left Logo -->
            <Image Source="Assets/logo_gcm.png" Height="60" Margin="25,5"/>

            <!-- Right Panel with Button and ToggleSwitch SIDE-BY-SIDE -->
            <StackPanel Grid.Column="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="10"
                Spacing="12">
                <Button Width="28" Height="28"
HorizontalAlignment="Center"
VerticalAlignment="Center"
Padding="0"
Background="Transparent"
BorderBrush="Transparent">
                    <FontIcon Glyph="&#xE946;" FontFamily="Segoe MDL2 Assets" Foreground="LightGray" FontSize="20"/>
                    <Button.Flyout>
                        <Flyout Placement="Top">
                            <TextBlock Text="You can choose to let GCM disable the default autostart applications to ensure you're not interrupted. Alternatively, you can manage this yourself by making sure no apps pop up that might interfere with GCM. This setting is optional."
               Width="250"
               TextWrapping="WrapWholeWords"
               Foreground="White"
               FontSize="12"
               Padding="5"/>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <!-- ToggleSwitch next to Button -->
                <Border CornerRadius="10"
        Padding="10"
        Margin="10"
        Width="300"
        Height="80"
        BorderBrush="SlateGray"
        BorderThickness="0"
                        >
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF2D2D30" Offset="0.0"/>
                            <GradientStop Color="#FF3E3E42" Offset="1.0"/>
                        </LinearGradientBrush>
                        
                    </Border.Background>

                    <!-- ToggleSwitch inside the panel -->
                    <ToggleSwitch x:Name="UsewinpartStartapps"
                  Header="Disable autostart apps"
                  OnContent="On"
                  OffContent="Off"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Toggled="UsewinpartStartapps_Toggled"/>

                    

                </Border>


                <!-- START GCM Button mit mehrfarbigem Verlauf -->
                <Button x:Name="MenuButton"
        Content="START GCM"
        CornerRadius="10"
        BorderBrush="SlateGray"
        BorderThickness="2"
        Foreground="White"
        Padding="12,6"
        Click="TopbarButton_Click"
        Height="50"
        Width="200"
                        
                        >

                    <!-- Farbverlauf als Hintergrund -->
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF2D2D30" Offset="0.0"/>
                            <GradientStop Color="#FF3E3E42" Offset="1.0"/>
                            <!-- Turquoise -->
                        </LinearGradientBrush>
                    </Button.Background>

                    <!-- Hover- und Klickzust‰nde -->
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Target="MenuButton.Opacity" Value="0.85"/>
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Target="MenuButton.Opacity" Value="0.6"/>
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                </Button>



            </StackPanel>
        </Grid>



        <!-- CommandBar at the top -->
        <!-- CommandBar for Update Status -->
        <CommandBar x:Name="UpdateBar"
            Grid.Row="1"
            Background="DarkOliveGreen"
            HorizontalAlignment="Stretch"
            OverflowButtonVisibility="Collapsed"
            Visibility="Collapsed">

            <CommandBar.PrimaryCommands>
                <!-- Progress display with text info -->
                <AppBarElementContainer>
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                        <ProgressBar x:Name="UpdateProgressBar"
                             Width="500"
                             Height="20"
                             Value="0"
                             IsIndeterminate="False"
                             ShowPaused="False"
                             ShowError="False"
                             Visibility="Collapsed"/>
                        <TextBlock x:Name="DownloadProgressText"
                           Foreground="White"
                           FontSize="12"
                           Visibility="Collapsed"
                           Margin="0,4,0,0"
                           Text="0 MB / 0 MB"/>
                    </StackPanel>
                </AppBarElementContainer>

                <!-- Update Info Text -->
                <AppBarElementContainer>
                    <TextBlock x:Name="UpdateBarText"
                       Text="Update Available"
                       Foreground="White"
                       FontSize="16"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Margin="10"/>
                </AppBarElementContainer>

                <!-- Update Trigger Button -->
                <AppBarButton x:Name="UpdateButton"
              Background="White"
              Foreground="Green"
              Visibility="Visible"
              Icon="Download"
              Label="Update"
              Click="UpdateButton_Click">
                    <AppBarButton.RenderTransform>
                        <ScaleTransform x:Name="UpdateButtonScale" ScaleX="1" ScaleY="1"/>
                    </AppBarButton.RenderTransform>
                </AppBarButton>


                <!-- Install Trigger Button -->
                <AppBarButton x:Name="InstallUpdateButton"
                      Background="White"
                      Foreground="Green"
                      Visibility="Collapsed"
                      Icon="OpenFile"
                      Label="Install"
                      Click="InstallUpdateButton_Click"/>
            </CommandBar.PrimaryCommands>
        </CommandBar>

        <!-- NavigationView filling the remaining space -->
        <NavigationView Grid.Row="2"
                        x:Name="nvMain"
                        PaneDisplayMode="Left"
                        SelectionChanged="NavigationView_SelectionChanged"
                        Background="#2A2A2A"
                        IsBackEnabled="True">
            
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Onboarding" Icon="Placeholder" Tag="OnboardingPage" />
                <NavigationViewItem Content="Launcher" Icon="StopSlideShow" Tag="LauncherPage" />
                <NavigationViewItem Content="Extensions" Icon="List"  Tag="StartupPage" />
                <NavigationViewItem Content="GCM Shortcuts" Icon="Add" Tag="shortcuts" />
                <NavigationViewItem Content="GCM Taskmanager" Icon="Pin"  Tag="TaskManagerPage" />
                <NavigationViewItem Content="Handheld specific" Icon="SwitchApps" Tag="Handheld">
                    <NavigationViewItem.MenuItems>
                        <NavigationViewItem Content="Rog Ally" Icon="DockBottom" Tag="RogAllyPage" />
                    </NavigationViewItem.MenuItems>
                </NavigationViewItem>
                <NavigationViewItemSeparator />
                <NavigationViewItem Content="additional features" Icon="ViewAll" Tag="Handheld">
                    <NavigationViewItem.MenuItems>
                        <NavigationViewItem Content="Links" Icon="Link" Tag="LinksPage" />
                    </NavigationViewItem.MenuItems>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="contentFrame">
                <Frame.ContentTransitions>
                    <TransitionCollection>
                        <NavigationThemeTransition />
                    </TransitionCollection>
                </Frame.ContentTransitions>
            </Frame>
        </NavigationView>
    </Grid>
</Window>
