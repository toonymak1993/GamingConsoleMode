<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GAMINGCONSOLEMODE.launcher"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:GAMINGCONSOLEMODE"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="LauncherItemBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
        </Style>
    </Page.Resources>

    <Grid Background="#121212">
        <SplitView x:Name="splitView" 
                   PaneBackground="#202020"
                   IsPaneOpen="True" 
                   OpenPaneLength="320" 
                   CompactPaneLength="60" 
                   DisplayMode="CompactInline">

            <SplitView.Pane>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,20,0,10">
                        <Grid>
                            <Button Content="&#xE700;" 
                                    FontFamily="Segoe MDL2 Assets"
                                    Width="50" Height="40"
                                    FontSize="16"
                                    Click="TogglePaneButton_Click"
                                    Background="Transparent" 
                                    BorderThickness="0"
                                    HorizontalAlignment="Left"
                                    Margin="5,0,0,0"/>

                            <TextBlock Text="Launchers" 
                                       FontSize="20" FontWeight="Bold" 
                                       VerticalAlignment="Center" 
                                       HorizontalAlignment="Right"
                                       Margin="0,0,20,0"/>
                        </Grid>

                        <TextBlock Text="Select default app" 
                                   FontSize="12" Foreground="#AAAAAA"
                                   HorizontalAlignment="Right" Margin="0,5,20,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="4">

                            <Border Style="{StaticResource LauncherItemBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="/Assets/launcher/steam_logo.png" Width="24" Height="24"/>
                                    <TextBlock Text="Steam" Grid.Column="1" VerticalAlignment="Center" Margin="15,0" FontWeight="SemiBold"/>
                                    <ToggleSwitch x:Name="use_steam_bp" Grid.Column="2" Toggled="use_steam_bp_Toggled" MinWidth="0" Margin="-80,-5,-10,-5"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource LauncherItemBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="/Assets/launcher/playnite_logo.png" Width="24" Height="24"/>
                                    <TextBlock Text="Playnite" Grid.Column="1" VerticalAlignment="Center" Margin="15,0" FontWeight="SemiBold"/>
                                    <ToggleSwitch x:Name="use_playnite" Grid.Column="2" Toggled="use_playnite_Toggled" MinWidth="0" Margin="-80,-5,-10,-5"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource LauncherItemBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="/Assets/launcher/xboxlogo.png" Width="24" Height="24"/>
                                    <TextBlock Text="Xbox App" Grid.Column="1" VerticalAlignment="Center" Margin="15,0" FontWeight="SemiBold"/>
                                    <ToggleSwitch x:Name="use_xbox" Grid.Column="2" Toggled="use_xbox_Toggled" MinWidth="0" Margin="-80,-5,-10,-5"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource LauncherItemBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="/Assets/launcher/geforcenow.png" Width="24" Height="24"/>
                                    <TextBlock Text="GeForce Now" Grid.Column="1" VerticalAlignment="Center" Margin="15,0" FontWeight="SemiBold"/>
                                    <ToggleSwitch x:Name="use_gfn" Grid.Column="2" Toggled="use_gfn_Toggled" MinWidth="0" Margin="-80,-5,-10,-5"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </SplitView.Pane>

            <Grid>
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#121212" Offset="0"/>
                        <GradientStop Color="#1E1E1E" Offset="1"/>
                    </LinearGradientBrush>
                </Grid.Background>

                <Grid x:Name="SteamPanel">
                    <Grid.Background>
                        <RadialGradientBrush Center="0.5,0.3" GradientOrigin="0.5,0.3" RadiusX="0.8" RadiusY="0.8">
                            <GradientStop Color="#1A2B45" Offset="0"/>
                            <GradientStop Color="#121212" Offset="1"/>
                        </RadialGradientBrush>
                    </Grid.Background>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="30" MaxWidth="600">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <Image Source="/Assets/launcher/steam_logo.png" Width="100" Height="100" HorizontalAlignment="Center"/>
                            <TextBlock Text="Steam Big Picture" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="GCM will launch Steam automatically." FontSize="14" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                            <HyperlinkButton Content="Download Steam" NavigateUri="https://store.steampowered.com/about/download" HorizontalAlignment="Center"/>
                        </StackPanel>

                    </StackPanel>
                </Grid>

                <Grid x:Name="PlaynitePanel" Visibility="Collapsed">
                    <Grid.Background>
                        <RadialGradientBrush Center="0.5,0.3" GradientOrigin="0.5,0.3" RadiusX="0.8" RadiusY="0.8">
                            <GradientStop Color="#4A2500" Offset="0"/>
                            <GradientStop Color="#121212" Offset="1"/>
                        </RadialGradientBrush>
                    </Grid.Background>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="30" MaxWidth="600">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <Image Source="/Assets/launcher/playnite_logo.png" Width="100" Height="100" HorizontalAlignment="Center"/>
                            <TextBlock Text="Playnite Fullscreen" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="GCM will launch Playnite automatically." FontSize="14" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                            <HyperlinkButton Content="Download Playnite" NavigateUri="https://playnite.link/" HorizontalAlignment="Center"/>
                        </StackPanel>

                      
                    </StackPanel>
                </Grid>

                <Grid x:Name="XboxPanel" Visibility="Collapsed">
                    <Grid.Background>
                        <RadialGradientBrush Center="0.5,0.3" GradientOrigin="0.5,0.3" RadiusX="0.8" RadiusY="0.8">
                            <GradientStop Color="#0F3300" Offset="0"/>
                            <GradientStop Color="#121212" Offset="1"/>
                        </RadialGradientBrush>
                    </Grid.Background>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="30" MaxWidth="600">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <Image Source="/Assets/launcher/Xboxlogo.png" Width="100" Height="100" HorizontalAlignment="Center"/>
                            <TextBlock Text="Xbox App" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="GCM will launch the Xbox App automatically." FontSize="14" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <muxc:InfoBar IsOpen="True" Severity="Informational" Title="System Integration" Message="The Xbox App is a Windows Store App and usually requires no path configuration." IsClosable="False"/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="gfnPanel" Visibility="Collapsed">
                    <Grid.Background>
                        <RadialGradientBrush Center="0.5,0.3" GradientOrigin="0.5,0.3" RadiusX="0.8" RadiusY="0.8">
                            <GradientStop Color="#1A3300" Offset="0"/>
                            <GradientStop Color="#121212" Offset="1"/>
                        </RadialGradientBrush>
                    </Grid.Background>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="30" MaxWidth="600">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <Image Source="/Assets/launcher/geforcenow.png" Width="100" Height="100" HorizontalAlignment="Center"/>
                            <TextBlock Text="GeForce Now" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Stream your games via cloud." FontSize="14" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                        </StackPanel>


                    </StackPanel>
                </Grid>


            </Grid>
        </SplitView>
    </Grid>
</Page>