<Page
    x:Class="GAMINGCONSOLEMODE.shortcuts"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:GAMINGCONSOLEMODE"
    mc:Ignorable="d">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <DataTemplate x:Key="ButtonIconTemplate" x:DataType="local:ButtonOption">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="{x:Bind Value}" 
                           VerticalAlignment="Center" 
                           Visibility="{x:Bind ShowText, Converter={StaticResource BoolToVis}}"/>

                <StackPanel Orientation="Horizontal" Spacing="8" 
                            Visibility="{x:Bind ShowIcons, Converter={StaticResource BoolToVis}}">
                    <Image Source="{x:Bind XboxIcon}" Width="24" Height="24" VerticalAlignment="Center"/>
                    <Image Source="{x:Bind PlayStationIcon}" Width="24" Height="24" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,24">
            <TextBlock Text="Controller Shortcuts" FontSize="28" FontWeight="Bold" FontFamily="Segoe UI Variable Display"/>
            <TextBlock Text="Customize your experience with custom button combos." 
                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" FontSize="14"/>
        </StackPanel>

        <Border Grid.Row="1" Margin="0,0,0,24" CornerRadius="8" 
                Background="#15FFFFFF" BorderBrush="#25FFFFFF" BorderThickness="1" Padding="16">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <FontIcon Glyph="&#xE7BA;" FontSize="24" VerticalAlignment="Top" Foreground="#FFCC00" Margin="0,2,0,0" FontFamily="{StaticResource SymbolThemeFontFamily}"/>

                <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Text="Guide Button Setup Note" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Text="Important: To use the Guide button, you must disable the 'Open Game Bar using Guide button' option in Windows Settings. Additionally, check Steam Big Picture settings (Settings > Controller > Guide Button Chord Layout). We recommend downloading and applying the community layout 'gamingconsolemode' (or unbinding the action manually) to prevent Steam from intercepting the input. Failure to do so may result in double inputs. This is a one-time setup." 
                               Opacity="0.8" FontSize="13" TextWrapping="Wrap" LineHeight="20"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
            <ItemsControl x:Name="FunctionsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander Margin="0,0,0,12" 
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch">
                            <Expander.Header>
                                <Grid ColumnSpacing="16" HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" 
                                              Glyph="&#xE7E7;" 
                                              Foreground="{ThemeResource SystemAccentColor}"
                                              VerticalAlignment="Center"
                                              Visibility="{Binding IsEnabled}"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,4">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="16"/>
                                        <TextBlock Text="{Binding Description}" Style="{ThemeResource CaptionTextBlockStyle}" 
                                                   Opacity="0.6" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <ToggleSwitch Grid.Column="2" IsOn="{Binding IsEnabled, Mode=TwoWay}" 
                                                  Toggled="Shortcut_Toggled" 
                                                  MinWidth="0" Margin="12,0,0,0"
                                                  VerticalAlignment="Center"/>
                                </Grid>
                            </Expander.Header>

                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" 
                                    Padding="20" CornerRadius="0,0,8,8">
                                <Grid ColumnSpacing="24" RowSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Primary Button" FontSize="12" FontWeight="SemiBold" Opacity="0.8"/>
                                        <ComboBox ItemsSource="{Binding AvailableButtons}" 
                                                  SelectedValue="{Binding Key1, Mode=TwoWay}"
                                                  SelectedValuePath="Value"
                                                  ItemTemplate="{StaticResource ButtonIconTemplate}"
                                                  SelectionChanged="ControlChanged" 
                                                  HorizontalAlignment="Stretch"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="8">
                                        <TextBlock Text="Secondary Button" FontSize="12" FontWeight="SemiBold" Opacity="0.8"/>
                                        <ComboBox ItemsSource="{Binding AvailableButtons}" 
                                                  SelectedValue="{Binding Key2, Mode=TwoWay}"
                                                  SelectedValuePath="Value"
                                                  ItemTemplate="{StaticResource ButtonIconTemplate}"
                                                  SelectionChanged="ControlChanged" 
                                                  HorizontalAlignment="Stretch"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Spacing="8" MinWidth="140">
                                        <TextBlock Text="Hold (Seconds)" FontSize="12" FontWeight="SemiBold" Opacity="0.8"/>
                                        <NumberBox Value="{Binding HoldTime, Mode=TwoWay}" 
                                                   Minimum="0" Maximum="5" 
                                                   SpinButtonPlacementMode="Inline"
                                                   ValueChanged="ControlChanged"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>