                                    </Button>
                                    <Button x:Name="AppLauncherTabFavoritesButton"
                                            Tag="Favorites"
                                            Height="48"
                                            MinWidth="150"
                                            Padding="18,0"
                                            CornerRadius="22"
                                            Click="AppLauncherTab_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE734;" FontSize="17"/>
                                            <TextBlock Text="Favorites" FontSize="15" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="AppLauncherTabDesktopButton"
                                            Tag="Desktop"
                                            Height="48"
                                            MinWidth="150"
                                            Padding="18,0"
                                            CornerRadius="22"
