<Window
    x:Class="gcmloader.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:gcmloader"
    Title="GCM TaskManager">

    <Grid Background="#FF010101">
        <Grid.Resources>
            <Style x:Key="PowerMenuStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
            </Style>
        </Grid.Resources>

        <Grid x:Name="RootGrid" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

            <ProgressRing IsActive="True" Opacity="0.01" Width="1" Height="1" 
                          HorizontalAlignment="Left" VerticalAlignment="Top"/>

            <MediaPlayerElement x:Name="BackgroundVideoPlayer" 
                                AutoPlay="True" 
                                Stretch="UniformToFill"
                                IsFullWindow="False"
                                Visibility="Collapsed"
                                Canvas.ZIndex="-2"/>

            <Grid x:Name="MainContent" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button x:Name="FocusSink" Width="0" Height="0" IsTabStop="True"/>

                <Image x:Name="BackgroundImage" Grid.RowSpan="3" Stretch="UniformToFill" IsHitTestVisible="False"/>

                <StackPanel x:Name="LauncherTileRow" Orientation="Horizontal" Visibility="Collapsed">
                    <Border x:Name="LauncherTile0"/>
                    <Border x:Name="LauncherTile1"/>
                    <Border x:Name="LauncherTile2"/>
                    <Border x:Name="LauncherTile3"/>
                    <Border x:Name="LauncherTile4"/>
                </StackPanel>

                <Border x:Name="infopanelright" Grid.Row="0"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        CornerRadius="18" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Top" 
                        Margin="20" 
                        Padding="12,8" 
                        BorderBrush="#33FFFFFF" 
                        BorderThickness="1" 
                        Canvas.ZIndex="100"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <CompositeTransform x:Name="InfoPanelTransform" ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>

                    <StackPanel Orientation="Horizontal" Spacing="18" VerticalAlignment="Center">
                        <StackPanel x:Name="ControllerStatusGroup" Orientation="Horizontal" Visibility="Collapsed" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE7FC;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{ThemeResource SystemAccentColorLight2}"/>
                            <TextBlock x:Name="ControllerBatteryText" Text="100%" FontSize="14" Foreground="White" Margin="6,0,0,0" FontWeight="SemiBold"/>
                        </StackPanel>

                        <FontIcon x:Name="NetworkStatusIcon" Glyph="&#xE701;" FontSize="16" Foreground="White" VerticalAlignment="Center"/>

                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <FontIcon x:Name="BatteryIcon" Glyph="&#xE83F;" FontSize="16" Foreground="White"/>
                            <TextBlock x:Name="BatteryPercentageText" Text="100%" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                        </StackPanel>

                        <Rectangle Width="1" Height="20" Fill="#22FFFFFF" VerticalAlignment="Center"/>

                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Button x:Name="ExitGcmButton" Width="50" Height="40" Click="ExitGcmButton_Click_1" 
                                    Background="Transparent" BorderThickness="0" CornerRadius="10"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                <Image Source="ms-appx:///Assets/windowsicon.png" Width="20" Height="20" Stretch="Uniform"/>
                            </Button>

                            <Button x:Name="MediaButton" Width="50" Height="40"
                                    Background="Transparent" BorderThickness="0" CornerRadius="10"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                <FontIcon Glyph="&#xE93C;" FontSize="18" Foreground="White"/>

                                <Button.Flyout>
                                    <Flyout x:Name="MediaFlyout" Placement="BottomEdgeAlignedRight" Opened="MediaFlyout_Opened">
                                        <Flyout.FlyoutPresenterStyle>
                                            <Style TargetType="FlyoutPresenter">
                                                <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}"/>
                                                <Setter Property="BorderBrush" Value="#33FFFFFF"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="CornerRadius" Value="16"/>
                                                <Setter Property="Padding" Value="10"/>
                                                <Setter Property="Margin"  Value="10"/>
                                                <Setter Property="MinWidth" Value="350"/>
                                            </Style>
                                        </Flyout.FlyoutPresenterStyle>

                                        <Grid Width="350" Padding="20">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0" Margin="0,0,0,15">
                                                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Left">
                                                    <FontIcon Glyph="&#xE93C;" FontSize="20" Foreground="{ThemeResource SystemAccentColorLight2}"/>
                                                    <TextBlock x:Name="MediaAppNameText" Text="Medien" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <Button x:Name="BtnLaunchSpotify" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" CornerRadius="8" Padding="10,5" Visibility="Collapsed" Click="BtnLaunchSpotify_Click">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <FontIcon Glyph="&#xE189;" FontSize="14" Foreground="#1DB954"/>
                                                        <TextBlock Text="Spotify" Foreground="#1DB954" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <StackPanel Grid.Row="1" Spacing="10">
                                                <Border Height="180" Background="#22FFFFFF" CornerRadius="12">
                                                    <Grid>
                                                        <FontIcon Glyph="&#xE93C;" FontSize="40" Opacity="0.2"/>
                                                        <Image x:Name="MediaCoverImage" Stretch="UniformToFill"/>
                                                    </Grid>
                                                </Border>

                                                <TextBlock x:Name="MediaTitleText" Text="Keine Medien aktiv" HorizontalAlignment="Center" FontWeight="Bold" FontSize="16" TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                <TextBlock x:Name="MediaArtistText" Text="" HorizontalAlignment="Center" Opacity="0.6" FontSize="14" TextTrimming="CharacterEllipsis" MaxLines="1"/>

                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="25" Margin="0,10,0,0">
                                                    <Button x:Name="BtnMediaPrev" Background="Transparent" BorderThickness="0" CornerRadius="10" Width="45" Height="45" Click="BtnMediaPrev_Click">
                                                        <FontIcon Glyph="&#xE892;" FontSize="20"/>
                                                    </Button>

                                                    <Button x:Name="BtnMediaPlayPause" Background="Transparent" BorderThickness="0" CornerRadius="12" Width="55" Height="55" Click="BtnMediaPlayPause_Click">
                                                        <FontIcon x:Name="IconMediaPlayPause" Glyph="&#xE768;" FontSize="28"/>
                                                    </Button>

                                                    <Button x:Name="BtnMediaNext" Background="Transparent" BorderThickness="0" CornerRadius="10" Width="45" Height="45" Click="BtnMediaNext_Click">
                                                        <FontIcon Glyph="&#xE893;" FontSize="20"/>
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>

                            <Button x:Name="VolumeButton" Width="50" Height="40" 
                                    Background="Transparent" BorderThickness="0" CornerRadius="10"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                <FontIcon Glyph="&#xE767;" FontSize="18" Foreground="White"/>
                            </Button>

                            <Button x:Name="SettingsButton" Width="50" Height="40" Click="SettingsButton_Click" 
                                    Background="Transparent" BorderThickness="0" CornerRadius="10"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                <FontIcon Glyph="&#xE713;" FontSize="18"/>
                            </Button>

                            <Button x:Name="AppLauncherButton" Width="50" Height="40" Click="ToggleAppLauncher_Click" 
                                    Background="Transparent" BorderThickness="0" CornerRadius="10"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                <FontIcon Glyph="&#xE71E;" FontSize="18"/>
                            </Button>

                            <Button x:Name="ShutdownButton" Width="50" Height="40" Click="PowerButton_Click" 
                                    Background="Transparent" BorderThickness="0" CornerRadius="10"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                <FontIcon Glyph="&#xE7E8;" FontSize="18"/>
                            </Button>
                        </StackPanel>

                        <Border Background="#15FFFFFF" CornerRadius="10" Padding="10,4">
                            <TextBlock x:Name="ClockText" FontSize="20" FontWeight="Bold" Foreground="White" FontFamily="Consolas" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2" HorizontalAlignment="Stretch" Margin="0,0,0,40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="LauncherColumn" Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition x:Name="CardsColumn" Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="60,0,0,0" Spacing="15">
                        <StackPanel x:Name="QuickLauncherPanel" Orientation="Horizontal" Spacing="15" Opacity="0" HorizontalAlignment="Left" Margin="10,0,0,0">
                            <Border x:Name="QuickSteam" Width="45" Height="45" CornerRadius="10" Background="#22FFFFFF" BorderThickness="2" BorderBrush="Transparent" Tag="steam">
                                <Image Source="ms-appx:///Assets/steam_logo.png" Width="26" Height="26" Stretch="Uniform"/>
                            </Border>
                            <Border x:Name="QuickPlaynite" Width="45" Height="45" CornerRadius="10" Background="#22FFFFFF" BorderThickness="2" BorderBrush="Transparent" Tag="playnite">
                                <Image Source="ms-appx:///Assets/playnite_logo.png" Width="26" Height="26" Stretch="Uniform"/>
                            </Border>
                            <Border x:Name="QuickXbox" Width="45" Height="45" CornerRadius="10" Background="#22FFFFFF" BorderThickness="2" BorderBrush="Transparent" Tag="xbox">
                                <Image Source="ms-appx:///Assets/xbox_logo.png" Width="26" Height="26" Stretch="Uniform"/>
                            </Border>
                            <Border x:Name="QuickGfn" Width="45" Height="45" CornerRadius="10" Background="#22FFFFFF" BorderThickness="2" BorderBrush="Transparent" Tag="gfn">
                                <Image Source="ms-appx:///Assets/geforcenow.png" Width="26" Height="26" Stretch="Uniform"/>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="LauncherAreaPanel" Orientation="Horizontal" Spacing="15" />
                    </StackPanel>

                    <Rectangle x:Name="ColumnSeparator" Grid.Column="1" Width="2" Fill="#33FFFFFF" Height="200" VerticalAlignment="Center" Margin="30,0,30,0"/>

                    <Grid Grid.Column="2">
                        <TextBlock x:Name="NoCardsMessage" Text="Nothing open" FontSize="22" Foreground="White" Opacity="0.5" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" />

                        <ScrollViewer x:Name="ProgramScrollViewer" 
                                      VerticalScrollBarVisibility="Disabled" 
                                      HorizontalScrollBarVisibility="Hidden" 
                                      HorizontalScrollMode="Enabled"
                                      VerticalAlignment="Stretch">
                            <StackPanel x:Name="ProgramCardPanel" 
                                        Orientation="Horizontal" 
                                        Spacing="10" 
                                        Padding="0,40,100,40" 
                                        VerticalAlignment="Center"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>

            <Border x:Name="FocusLossOverlay" Background="#D8000000" Visibility="Collapsed" Canvas.ZIndex="999">
                <Image Source="/Assets/gcm_ui_logo.png" HorizontalAlignment="Center" VerticalAlignment="Center" Width="200" Height="200"/>
            </Border>

            <Grid x:Name="AudioOverlay" Visibility="Collapsed" Canvas.ZIndex="2000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Opacity="0">

                <Grid Tapped="AudioOverlay_Tapped">
                    <Grid.Background>
                        <AcrylicBrush TintColor="#050505" TintOpacity="0.85" FallbackColor="#CC000000" />
                    </Grid.Background>
                </Grid>

                <Grid x:Name="AudioPanelContent" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid.RenderTransform>
                        <CompositeTransform x:Name="AudioPanelTransform" TranslateY="100"/>
                    </Grid.RenderTransform>

                    <Border Width="650" VerticalAlignment="Center" HorizontalAlignment="Center" 
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            CornerRadius="24" BorderBrush="#33FFFFFF" BorderThickness="1"
                            Padding="0">
                        <Border.Shadow>
                            <ThemeShadow/>
                        </Border.Shadow>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="30,25,30,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="TabHeaderDevices" Grid.Column="0" CornerRadius="12" Padding="0,10" Background="#22FFFFFF">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                                        <FontIcon Glyph="&#xE7F5;" FontSize="18"/>
                                        <TextBlock Text="Output Devices" FontWeight="Bold" FontSize="16"/>
                                    </StackPanel>
                                </Border>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Opacity="0.6" Margin="20,0">
                                    <Border CornerRadius="6" BorderBrush="#88FFFFFF" BorderThickness="1.5" Padding="6,2">
                                        <TextBlock Text="LB" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                    <FontIcon Glyph="&#xE76B;" FontSize="12"/>
                                    <Border CornerRadius="6" BorderBrush="#88FFFFFF" BorderThickness="1.5" Padding="6,2">
                                        <TextBlock Text="RB" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>

                                <Border x:Name="TabHeaderMixer" Grid.Column="2" CornerRadius="12" Padding="0,10" Background="Transparent" Opacity="0.5">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                                        <FontIcon Glyph="&#xE995;" FontSize="18"/>
                                        <TextBlock Text="App Mixer" FontWeight="Bold" FontSize="16"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border x:Name="MasterVolumeContainer" Grid.Row="1" Margin="30,5,30,15" 
                                    Background="#0AFFFFFF" CornerRadius="12" Padding="15"
                                    BorderThickness="1" BorderBrush="Transparent">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <FontIcon x:Name="MasterVolumeIcon" Glyph="&#xE767;" FontSize="20" Foreground="White" Margin="0,0,15,0" VerticalAlignment="Center"/>

                                    <Slider x:Name="MasterVolumeSlider" Grid.Column="1" VerticalAlignment="Center" 
                                            Minimum="0" Maximum="100" Value="50" 
                                            ValueChanged="MasterVolumeSlider_ValueChanged"
                                            IsThumbToolTipEnabled="False"/>

                                    <TextBlock x:Name="MasterVolumeText" Grid.Column="2" Text="50%" FontSize="16" FontWeight="Bold" Foreground="White" Margin="15,0,0,0" VerticalAlignment="Center" Width="45" TextAlignment="Right"/>
                                </Grid>
                            </Border>

                            <Rectangle Grid.Row="2" Height="1" Fill="#1AFFFFFF" Margin="30,0"/>

                            <Grid Grid.Row="3" Margin="20,15">
                                <ScrollViewer x:Name="AudioDevicesScrollViewer" MaxHeight="400" VerticalScrollBarVisibility="Hidden" HorizontalScrollMode="Disabled">
                                    <StackPanel x:Name="SimpleAudioList" Spacing="10"/>
                                </ScrollViewer>

                                <ScrollViewer x:Name="AudioMixerScrollViewer" MaxHeight="400" VerticalScrollBarVisibility="Hidden" HorizontalScrollMode="Disabled" Visibility="Collapsed">
                                    <StackPanel x:Name="MixerListStackPanel" Spacing="10"/>
                                </ScrollViewer>
                            </Grid>

                            <Border Grid.Row="4" Background="#0FFFFFFF" CornerRadius="0,0,24,24" Padding="0,12">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="25">

                                    <StackPanel x:Name="LegendDevices" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Ellipse Width="16" Height="16" Fill="#FFA5D952"/>
                                        <TextBlock Text="Select" Foreground="#EEFFFFFF" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel x:Name="LegendMixer" Orientation="Horizontal" Spacing="8" Visibility="Collapsed" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE76B;" FontSize="14" Opacity="0.8" Foreground="White"/>
                                        <TextBlock Text="Adj. Volume" Foreground="#EEFFFFFF" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Ellipse Width="16" Height="16" Fill="#FFFFD100"/>
                                        <TextBlock Text="Master Vol" Foreground="#EEFFFFFF" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Ellipse Width="16" Height="16" Fill="#FFDB4E4E"/>
                                        <TextBlock Text="Close" Foreground="#EEFFFFFF" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <StackPanel x:Name="NotificationStack"
                        Orientation="Vertical"
                        VerticalAlignment="Bottom" 
                        HorizontalAlignment="Right"
                        Margin="0,0,20,50"
                        Canvas.ZIndex="1000"
                        Width="400"
                        Spacing="10"
                        IsHitTestVisible="True"/>

            <Grid x:Name="PowerMenu" Visibility="Collapsed" Canvas.ZIndex="3000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Grid.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="30" />
                        <ContentThemeTransition/>
                    </TransitionCollection>
                </Grid.ChildrenTransitions>

                <Grid Tapped="PowerMenu_BackdropTapped">
                    <Grid.Background>
                        <AcrylicBrush TintColor="#050505" TintOpacity="0.85" FallbackColor="#CC000000" />
                    </Grid.Background>
                </Grid>

                <Border Width="380" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        CornerRadius="16" BorderBrush="#33FFFFFF" BorderThickness="1"
                        Padding="0">
                    <Border.Shadow>
                        <ThemeShadow/>
                    </Border.Shadow>

                    <StackPanel>
                        <Border Background="#10FFFFFF" CornerRadius="16,16,0,0" Padding="15">
                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE7E8;" FontSize="18" Foreground="White"/>
                                <TextBlock Text="POWER MENU" FontWeight="Bold" FontSize="16" Foreground="White"/>
                            </StackPanel>
                        </Border>

                        <StackPanel Spacing="8" Padding="20">

                            <Button x:Name="SleepMenuItem" Click="SleepMenuItem_Click"
                                    HorizontalAlignment="Stretch" Height="70" CornerRadius="8"
                                    BorderThickness="1" BorderBrush="#44FFFFFF" Background="#25FFFFFF"
                                    Padding="15,0">
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <FontIcon Glyph="&#xE740;" FontSize="24" VerticalAlignment="Center" Foreground="#A5D952"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                                        <TextBlock Text="Sleep Mode" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="❄" FontSize="12" Foreground="#A5D952"/>
                                            <TextBlock Text="Suspends current Game" FontSize="12" Opacity="0.7" Foreground="#A5D952"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button x:Name="RestartMenuItem" Click="RestartMenuItem_Click"
                                    HorizontalAlignment="Stretch" Height="55" CornerRadius="8"
                                    Background="#10FFFFFF" BorderThickness="0" Padding="15,0">
                                <StackPanel Orientation="Horizontal" Spacing="20">
                                    <FontIcon Glyph="&#xE777;" FontSize="20" Foreground="White"/>
                                    <TextBlock Text="Restart System" FontSize="15" VerticalAlignment="Center" Foreground="White"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="ShutdownMenuItem" Click="ShutdownMenuItem_Click"
                                    HorizontalAlignment="Stretch" Height="55" CornerRadius="8"
                                    Background="#10FFFFFF" BorderThickness="0" Padding="15,0">
                                <StackPanel Orientation="Horizontal" Spacing="20">
                                    <FontIcon Glyph="&#xE7E8;" FontSize="20" Foreground="White"/>
                                    <TextBlock Text="Shutdown System" FontSize="15" VerticalAlignment="Center" Foreground="White"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="LogOffMenuItem" Click="LogOffMenuItem_Click"
                                    HorizontalAlignment="Stretch" Height="55" CornerRadius="8"
                                    Background="#10FFFFFF" BorderThickness="0" Padding="15,0">
                                <StackPanel Orientation="Horizontal" Spacing="20">
                                    <FontIcon Glyph="&#xE77B;" FontSize="20" Foreground="White"/>
                                    <TextBlock Text="Log Off" FontSize="15" VerticalAlignment="Center" Foreground="White"/>
                                </StackPanel>
                            </Button>

                        </StackPanel>

                        <Border BorderBrush="#15FFFFFF" BorderThickness="0,1,0,0" Padding="15">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                                <Ellipse Width="18" Height="18" Fill="#FFDB4E4E"/>
                                <TextBlock Text="Back / Close" Foreground="#AAFFFFFF" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <MediaPlayerElement x:Name="StartupVideoPlayer" AreTransportControlsEnabled="False" Stretch="Uniform" Background="Black" Canvas.ZIndex="1500"/>

            <Grid x:Name="GameOptionsOverlay" Visibility="Collapsed" Canvas.ZIndex="500" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Grid.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="40" />
                        <ContentThemeTransition/>
                    </TransitionCollection>
                </Grid.ChildrenTransitions>

                <Grid Tapped="GameOptionsOverlay_BackdropTapped">
                    <Grid.Background>
                        <AcrylicBrush TintColor="#050505" TintOpacity="0.85" FallbackColor="#CC000000" />
                    </Grid.Background>
                </Grid>

                <Border x:Name="GameOptionsMenuBorder" Width="500" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        CornerRadius="16" BorderBrush="#33FFFFFF" BorderThickness="1"
                        Padding="0">
                    <Border.Shadow>
                        <ThemeShadow/>
                    </Border.Shadow>

                    <Grid>
                        <StackPanel x:Name="GameOptionsMainPanel" Spacing="0">
                            <Border Background="#10FFFFFF" CornerRadius="16,16,0,0" Padding="20">
                                <StackPanel>
                                    <TextBlock x:Name="GameOptionsTitle" Text="GAME OPTIONS" FontWeight="Bold" FontSize="18" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="GameOptionsSubtitle" Text="Selected: ELEX 2" FontSize="14" Opacity="0.7" Foreground="White" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Spacing="10" Padding="30">

                                <Button x:Name="BtnSuspendGame" Click="BtnSuspendGame_Click"
                                        HorizontalAlignment="Stretch" Height="70" CornerRadius="8"
                                        BorderThickness="1" BorderBrush="#33FFFFFF" Background="#20FFFFFF"
                                        Padding="15,0">
                                    <Grid HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <FontIcon x:Name="IconSuspend" Glyph="&#xE769;" FontSize="24" VerticalAlignment="Center" Foreground="#A5D952"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                                            <TextBlock x:Name="TxtSuspendTitle" Text="Suspend Game" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                                            <TextBlock x:Name="TxtSuspendDesc" Text="Freezes the game to save resources" FontSize="12" Opacity="0.7" Foreground="White"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button x:Name="BtnChangeArtwork" Click="BtnChangeArtwork_Click"
                                        HorizontalAlignment="Stretch" Height="70" CornerRadius="8"
                                        BorderThickness="1" BorderBrush="#33FFFFFF" Background="#10FFFFFF"
                                        Padding="15,0">
                                    <Grid HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE7B5;" FontSize="24" VerticalAlignment="Center" Foreground="White"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                                            <TextBlock Text="Change Artwork" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                                            <TextBlock Text="Search SteamGridDB for new covers" FontSize="12" Opacity="0.7" Foreground="White"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                            </StackPanel>

                            <Border BorderBrush="#15FFFFFF" BorderThickness="0,1,0,0" Padding="15">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                                    <Ellipse Width="18" Height="18" Fill="#FFDB4E4E"/>
                                    <TextBlock Text="Back / Close" Foreground="#AAFFFFFF" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Grid x:Name="ArtworkSearchPanel" Visibility="Collapsed" Padding="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Click="BtnBackToOptions_Click" Background="Transparent" BorderThickness="0">
                                    <FontIcon Glyph="&#xE72B;" FontSize="18"/>
                                </Button>
                                <TextBox x:Name="ImageSearchBox" Grid.Column="1" Margin="10,0,0,0" PlaceholderText="Search Game..." Height="40" CornerRadius="5" FontSize="16"/>
                                <Button x:Name="ImageSearchButton" Content="Search" Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,5,0" Height="32" Click="ImageSearchButton_Click" Style="{StaticResource AccentButtonStyle}"/>
                            </Grid>
                            <ProgressBar x:Name="ImageSearchProgress" Grid.Row="0" VerticalAlignment="Bottom" IsIndeterminate="true" Visibility="Collapsed" Height="2" Margin="0,5,0,0"/>

                            <GridView x:Name="ImageResultsGrid" Grid.Row="1" Margin="0,10" SelectionMode="Single" IsItemClickEnabled="True" ItemClick="ImageResultsGrid_ItemClick">
                                <GridView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="140" Height="210" CornerRadius="8" Margin="6" Background="#222">
                                            <Image Source="{Binding}" Stretch="UniformToFill"/>
                                        </Border>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>

                            <TextBlock x:Name="NoImagesFoundText" Grid.Row="1" Text="No images found." VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#888" FontSize="16" Visibility="Collapsed"/>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20">
                                <Button x:Name="BrowseLocalButton" Content="📂 Browse Local..." Width="160" Height="40" CornerRadius="8" Click="BrowseLocalButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="AppLauncher" Visibility="Collapsed" Background="#D8000000" Canvas.ZIndex="900" Tapped="AppLauncher_Tapped">
                <Border VerticalAlignment="Center" HorizontalAlignment="Center" Width="800" Height="600" Background="#E51C1C1C" CornerRadius="12" BorderBrush="#55FFFFFF" BorderThickness="1" Tapped="AppLauncherContent_Tapped">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Height="45" Margin="20,15,20,10" Background="#22FFFFFF" CornerRadius="22">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE721;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="White"/>
                                <TextBox x:Name="AppSearchBox" Grid.Column="1" Margin="10,0,15,0" PlaceholderText="Search..." TextChanged="AppSearchBox_TextChanged" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Foreground="White"/>
                            </Grid>
                        </Border>
                        <Grid Grid.Row="1">
                            <GridView x:Name="AppGridView" ItemsSource="{x:Bind AllInstalledApps}" IsItemClickEnabled="True" ItemClick="AppGridView_ItemClick" Padding="20">
                                <GridView.ItemTemplate>
                                    <DataTemplate x:DataType="local:AppInfo">
                                        <StackPanel Width="150" Margin="10">
                                            <Image Source="{x:Bind Icon}" Width="64" Height="64" Stretch="Uniform"/>
                                            <TextBlock Text="{x:Bind Name}" HorizontalAlignment="Center" TextAlignment="Center" MaxLines="2" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>
                            <ProgressRing x:Name="AppLoadingRing" IsActive="False" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Width="50" Height="50"/>
                            <TextBlock x:Name="NoAppsFoundText" Text="No apps found" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock x:Name="NoSearchResultsText" Text="No results" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

        </Grid>
    </Grid>
</Window>