                    <Grid.Background>
                        <AcrylicBrush TintColor="#04070C" TintOpacity="0.9" FallbackColor="#E6000000" />
                    </Grid.Background>
                </Grid>

                <Border Width="720"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Background="#D0121A28"
                        CornerRadius="30"
                        BorderBrush="#44FFFFFF"
                        BorderThickness="1"
                        Padding="30"
                        Tapped="WindowsReturnConfirmContent_Tapped">
                    <Border.Shadow>
                        <ThemeShadow/>
                    </Border.Shadow>

                    <StackPanel Spacing="24">
                        <StackPanel HorizontalAlignment="Center" Spacing="12">
                            <Border Width="92"
                                    Height="92"
                                    CornerRadius="28"
                                    Background="#18FFFFFF">
                                <Image Source="ms-appx:///Assets/windowsicon.png"
                                       Width="52"
                                       Height="52"
                                       Stretch="Uniform"
