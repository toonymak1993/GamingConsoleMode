                                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE756;" FontSize="17"/>
                                            <TextBlock Text="Desktop" FontSize="15" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="AppLauncherTabMicrosoftButton"
                                            Tag="Microsoft"
                                            Height="48"
                                            MinWidth="150"
                                            Padding="18,0"
