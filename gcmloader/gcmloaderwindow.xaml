<Window
    x:Class="gcmloader.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="GCM TaskManager">

    <Grid x:Name="RootGrid">
        <Grid.Resources>
            <Style x:Key="PowerMenuStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
            </Style>
        </Grid.Resources>

        <Grid x:Name="MainContent" Visibility="Collapsed">

            <Button x:Name="FocusSink" Width="0" Height="0" IsTabStop="True"/>
            <StackPanel x:Name="LauncherTileRow"
                        Orientation="Horizontal"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        Loaded="LauncherTileRow_Loaded"
                        VerticalAlignment="Top"
                        Margin="0,40,0,0"
                        Spacing="20">
                <Border Width="120" Height="140" x:Name="LauncherTile0"/>
                <Border Width="120" Height="140" x:Name="LauncherTile1"/>
                <Border Width="120" Height="140" x:Name="LauncherTile2"/>
                <Border Width="120" Height="140" x:Name="LauncherTile3"/>
                <Border Width="120" Height="140" x:Name="LauncherTile4"/>
            </StackPanel>

            <Image x:Name="BackgroundImage"
                   Stretch="UniformToFill"
                   IsHitTestVisible="False"/>

            <Border x:Name="infopanelright"
                    Background="#88000000"
                    CornerRadius="10"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="20" Padding="10">
                <Grid ColumnSpacing="15" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">

                        <!-- HINZUGEFÜGT: STATUS-ICONS -->
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="0,0,15,0">
                            <FontIcon x:Name="NetworkStatusIcon" Glyph="&#xE701;" FontSize="16" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon x:Name="BatteryIcon" Glyph="&#xE83F;" FontSize="16" Foreground="White"/>
                                <TextBlock x:Name="BatteryPercentageText" Text="100%" FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Bestehende Buttons -->
                        <Button x:Name="ExitGcmButton" Width="50" Height="40" Click="ExitGcmButton_Click_1">
                            <ToolTipService.ToolTip>
                                <TextBlock Text="Zurück zum Desktop"/>
                            </ToolTipService.ToolTip>
                            <FontIcon Glyph="&#xf1cb;" FontSize="18"/>
                        </Button>

                        <Button x:Name="ShutdownButton" Width="50" Height="40" Click="PowerButton_Click">
                            <ToolTipService.ToolTip>
                                <TextBlock Text="Power-Menü"/>
                            </ToolTipService.ToolTip>
                            <FontIcon Glyph="&#xe7e8;" FontSize="18"/>
                        </Button>
                    </StackPanel>

                    <TextBlock x:Name="ClockText" Grid.Column="1" FontSize="24" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" FontFamily="Consolas"/>
                </Grid>
            </Border>

            <Grid VerticalAlignment="Bottom"      
                  Height="420"
                  HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="LauncherColumn" Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition x:Name="CardsColumn" Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel x:Name="LauncherAreaPanel"  
                            Grid.Column="0"  
                            Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center"  
                            HorizontalAlignment="Left"  
                            Margin="60,0,0,0">
                </StackPanel>

                <Rectangle x:Name="ColumnSeparator" Grid.Column="1"
                           Width="2"
                           Fill="#55FFFFFF"
                           Height="200"
                           RadiusX="1" RadiusY="1"
                           VerticalAlignment="Center"
                           Margin="40,0,40,0"/>

                <ScrollViewer x:Name="ProgramScrollViewer"
                              Grid.Column="2"
                              VerticalScrollBarVisibility="Disabled"
                              VerticalAlignment="Center"
                              Padding="0,0,60,0"
                              HorizontalScrollMode="Enabled"    
                              HorizontalScrollBarVisibility="Hidden">
                    <StackPanel x:Name="ProgramCardPanel" Orientation="Horizontal"/>
                </ScrollViewer>
            </Grid>

            <Border Height="60"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop Color="#CC000000" Offset="0.0"/>
                        <GradientStop Color="Transparent" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="40">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                        <TextBlock Text="A" FontSize="22" FontWeight="Bold" Foreground="#FFA5D952"/>
                        <TextBlock Text="Start" FontSize="16" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                        <TextBlock Text="B" FontSize="22" FontWeight="Bold" Foreground="#FFDB4E4E"/>
                        <TextBlock Text="Close" FontSize="16" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                        <TextBlock Text="LB" FontSize="22" FontWeight="Bold" Foreground="#FF4E97D9"/>
                        <TextBlock Text="Previous Area" FontSize="16" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                        <TextBlock Text="RB" FontSize="22" FontWeight="Bold" Foreground="#FF4E97D9"/>
                        <TextBlock Text="Next Area" FontSize="16" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Border x:Name="FocusLossOverlay"
                Background="#D8000000" Visibility="Collapsed"
                Canvas.ZIndex="99">
            <Grid>
                <Image Source="/Assets/gcm_ui_logo.png"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Width="200"
                       Height="200"
                       Stretch="Uniform"/>
            </Grid>
        </Border>

        <MediaPlayerElement x:Name="StartupVideoPlayer"
                              AreTransportControlsEnabled="False"
                              Stretch="Uniform"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="Black"/>

        <Border x:Name="PowerMenu"
                Visibility="Collapsed"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="#CC1C1C1C"
                CornerRadius="8"
                BorderBrush="#55FFFFFF"
                BorderThickness="1"
                Canvas.ZIndex="100">
            <StackPanel Spacing="5" Margin="5">
                <Button x:Name="ShutdownMenuItem" Style="{StaticResource PowerMenuStyle}" Click="ShutdownMenuItem_Click">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xe7e8;" FontSize="16"/>
                        <TextBlock Text="Shutdown"/>
                    </StackPanel>
                </Button>
                <Button x:Name="RestartMenuItem" Style="{StaticResource PowerMenuStyle}" Click="RestartMenuItem_Click">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xe777;" FontSize="16"/>
                        <TextBlock Text="Restart"/>
                    </StackPanel>
                </Button>
                <Button x:Name="SleepMenuItem" Style="{StaticResource PowerMenuStyle}" Click="SleepMenuItem_Click">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xe740;" FontSize="16"/>
                        <TextBlock Text="Sleep"/>
                    </StackPanel>
                </Button>
                <Button x:Name="LogOffMenuItem" Style="{StaticResource PowerMenuStyle}" Click="LogOffMenuItem_Click">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xe77b;" FontSize="16"/>
                        <TextBlock Text="Log Off"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>