                                    HorizontalContentAlignment="Stretch">
                                <Grid Padding="18,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image x:Name="WindowsReturnConfirmIcon"
                                           Source="ms-appx:///Assets/controllericons/xbox/A.png"
                                           Width="42"
                                           Height="42"
                                           Stretch="Uniform"
                                           VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center" Spacing="3">
                                        <TextBlock Text="Return"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="White"/>
                                        <TextBlock Text="Leave GCM and restore Windows shell"
                                                   FontSize="13"
                                                   Foreground="#CCFFFFFF"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button x:Name="WindowsReturnCancelButton"
                                    Grid.Column="1"
                                    Height="118"
                                    CornerRadius="24"
                                    IsTabStop="False"
                                    UseSystemFocusVisuals="False"
                                    Background="#18FFFFFF"
                                    BorderBrush="#28FFFFFF"
                                    BorderThickness="1"
                                    Click="WindowsReturnCancelButton_Click"
                                    HorizontalContentAlignment="Stretch">
