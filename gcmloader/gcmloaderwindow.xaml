                                                    Background="#22FFFFFF"
                                                    VerticalAlignment="Top">
                                                <FontIcon x:Name="SettingsContextGlyph"
                                                          Glyph="&#xE7BF;"
                                                          FontSize="24"
                                                          Foreground="White"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="16,0,0,0" Spacing="6">
                                                <TextBlock x:Name="SettingsContextTitle"
                                                           Text="Steam"
                                                           FontSize="20"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"/>
                                                <TextBlock x:Name="SettingsContextText"
                                                           Text="Pick the active category on the left, then adjust the details on the right."
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Opacity="0.78"
                                                           Foreground="White"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <ScrollViewer x:Name="SettingsScrollViewer"
                                                  Grid.Row="2"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel x:Name="SettingsRowsHost" Spacing="16"/>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Grid.Row="2"
                                Background="#08FFFFFF"
                                CornerRadius="0,0,28,28"
                                BorderBrush="#15FFFFFF"
                                BorderThickness="0,1,0,0"
                                Padding="18,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="SettingsFooterText"
                                           Text="Use D-Pad to move. Press A to apply a setting."
                                           Foreground="#CCFFFFFF"
                                           FontSize="13"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1"
                                           Text="Steam-only mode active"
                                           Foreground="#99FFFFFF"
                                           FontSize="13"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

        </Grid>
    </Grid>
</Window>
