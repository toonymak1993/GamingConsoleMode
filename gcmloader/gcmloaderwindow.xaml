                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Padding="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="320"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

