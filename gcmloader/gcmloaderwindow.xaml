                                    <Style TargetType="GridViewItem">
                                        <Setter Property="Margin" Value="8"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </GridView.ItemContainerStyle>
                                <GridView.ItemTemplate>
                                    <DataTemplate x:DataType="local:AppInfo">
                                        <Border Width="180"
                                                Height="186"
                                                CornerRadius="24"
                                                Background="#20F5FAFF"
                                                BorderBrush="#28FFFFFF"
                                                BorderThickness="1.2"
                                                Padding="16">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Grid>
                                                    <TextBlock Text="{x:Bind SourceLabel}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="#BFE8F2FF"
                                                               CharacterSpacing="75"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxLines="1"/>
                                                    <TextBlock Text="{x:Bind FavoriteGlyph}"
                                                               HorizontalAlignment="Right"
                                                               Foreground="#FFFFD36A"
                                                               Opacity="{x:Bind FavoriteOpacity}"
                                                               FontSize="18"
                                                               FontWeight="Bold"/>
                                                </Grid>

                                                <Border Grid.Row="1"
                                                        Width="70"
                                                        Height="70"
                                                        CornerRadius="22"
                                                        Background="#26000000"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                    <Image Source="{x:Bind Icon}"
                                                           Width="54"
                                                           Height="54"
                                                           Stretch="Uniform"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                </Border>

                                                <Border Grid.Row="2"
                                                        Background="#B0070E22"
                                                        CornerRadius="16"
                                                        Padding="11,8">
                                                    <TextBlock Text="{x:Bind Name}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               TextWrapping="Wrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxLines="2"
                                                               TextAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>

                            <ProgressRing x:Name="AppLoadingRing"
                                          IsActive="False"
                                          Visibility="Collapsed"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Width="70"
                                          Height="70"/>
                            <TextBlock x:Name="NoAppsFoundText"
                                       Text="No installed apps found"
                                       Visibility="Collapsed"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#CCFFFFFF"
                                       FontSize="24"
                                       FontWeight="SemiBold"/>
                            <TextBlock x:Name="NoSearchResultsText"
                                       Text="No apps match this filter"
                                       Visibility="Collapsed"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#CCFFFFFF"
                                       FontSize="24"
                                       FontWeight="SemiBold"/>
                        </Grid>

                        <Border Grid.Row="4"
                                Margin="0,14,0,0"
                                Background="#14FFFFFF"
                                BorderBrush="#18FFFFFF"
                                BorderThickness="1"
                                CornerRadius="20"
                                Padding="18,12">
                            <TextBlock x:Name="AppLauncherHintText"
                                       Text="LB/RB changes tabs. A launches, X toggles favorites, B closes."
                                       Foreground="#CCFFFFFF"
                                       FontSize="14"
                                       HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="WindowsReturnConfirmOverlay"
                  Visibility="Collapsed"
                  Canvas.ZIndex="3100"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
