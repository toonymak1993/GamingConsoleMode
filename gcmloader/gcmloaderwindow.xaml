<Window
    x:Class="gcmloader.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="GCM TaskManager">

    <Grid>
        <StackPanel x:Name="LauncherTileRow"
    Orientation="Horizontal"
    Visibility="Collapsed"
    HorizontalAlignment="Center"
    VerticalAlignment="Top"
    Margin="0,40,0,0"
    Spacing="20">
            <Border Width="120" Height="140" BorderBrush="Gray" BorderThickness="2" CornerRadius="15" Background="#66FFFFFF" x:Name="LauncherTile0"/>
            <Border Width="120" Height="140" BorderBrush="Gray" BorderThickness="2" CornerRadius="15" Background="#66FFFFFF" x:Name="LauncherTile1"/>
            <Border Width="120" Height="140" BorderBrush="Gray" BorderThickness="2" CornerRadius="15" Background="#66FFFFFF" x:Name="LauncherTile2"/>
            <Border Width="120" Height="140" BorderBrush="Gray" BorderThickness="2" CornerRadius="15" Background="#66FFFFFF" x:Name="LauncherTile3"/>
            <Border Width="120" Height="140" BorderBrush="Gray" BorderThickness="2" CornerRadius="15" Background="#66FFFFFF" x:Name="LauncherTile4"/>
        </StackPanel>

        <!-- Hintergrundbild -->
        <Image x:Name="BackgroundImage"
               Stretch="UniformToFill"
               IsHitTestVisible="False"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch"
               Opacity="0.2"/>

        <!-- Info-Leiste oben rechts -->
        <Border CornerRadius="10"
                x:Name="infopanelright"
                Background="#88000000"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Visibility="Collapsed"
                Margin="20"
                Padding="10">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Button Content="📶" Width="40" Height="40" Click="WifiButton_Click"/>
                <Button Content="ᛒ"  Width="40" Height="40" Click="BluetoothButton_Click"/>
                <TextBlock x:Name="ClockText"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Hauptbereich: horizontale Kartenliste -->
        <ScrollViewer x:Name="ProgramScrollViewer"
              HorizontalScrollBarVisibility="Visible"
              VerticalScrollBarVisibility="Disabled"
              HorizontalAlignment="Center"
              VerticalAlignment="Bottom"
              Padding="60">
            <StackPanel x:Name="ProgramCardPanel"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="40"/>
        </ScrollViewer>

        <!-- Unten: Controller-Tastenleiste mit Farbverlauf -->
        <Border Height="60"
        VerticalAlignment="Bottom"
        HorizontalAlignment="Stretch">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF2D2D30" Offset="0.0"/>
                    <GradientStop Color="#FF3E3E42" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>

            <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="40">
                <!-- A Button Info -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                    <TextBlock Text="A" FontSize="22" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="Start" FontSize="16" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- B Button Info -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                    <TextBlock Text="B" FontSize="22" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="Close" FontSize="16" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

               
            </StackPanel>
        </Border>


    </Grid>
</Window>
