                                    <TextBlock Text="/" FontSize="13" Foreground="#88FFFFFF"/>
                                    <TextBlock Text="RB" FontSize="13" FontWeight="Bold" Foreground="#E8FFFFFF"/>
                                    <TextBlock Text="Tabs" FontSize="14" Foreground="#CCFFFFFF"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Height="54"
                                    Background="#1AFFFFFF"
                                    BorderBrush="#24FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="24"
                                    Padding="18,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xE721;"
                                              FontFamily="Segoe Fluent Icons"
                                              VerticalAlignment="Center"
                                              Foreground="#DDFFFFFF"
                                              FontSize="18"/>
