<Window
    x:Class="gcmloader.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="GCM TaskManager">
  
    <Grid>
        <!-- Hintergrundbild -->
        <Image x:Name="BackgroundImage"
               Stretch="UniformToFill"
               IsHitTestVisible="False"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch"
               Opacity="0.2"/>

        <!-- Info-Leiste oben rechts -->
        <Border CornerRadius="10"
                Background="#88000000"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="20"
                Padding="10">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Button Content="📶" Width="40" Height="40" Click="WifiButton_Click"/>
                <Button Content="🟦" Width="40" Height="40" Click="BluetoothButton_Click"/>
                <TextBlock x:Name="ClockText"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Hauptbereich: horizontale Kartenliste -->
        <ScrollViewer x:Name="ProgramScrollViewer"
              HorizontalScrollBarVisibility="Visible"
              VerticalScrollBarVisibility="Disabled"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Padding="60">
            <StackPanel x:Name="ProgramCardPanel"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="40"/>
        </ScrollViewer>

    </Grid>
</Window>
