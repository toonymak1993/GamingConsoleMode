                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image x:Name="WindowsReturnCancelIcon"
                                           Source="ms-appx:///Assets/controllericons/xbox/B.png"
                                           Width="42"
                                           Height="42"
                                           Stretch="Uniform"
                                           VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center" Spacing="3">
                                        <TextBlock Text="Stay in GCM"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="White"/>
                                        <TextBlock Text="Close this prompt and keep playing"
                                                   FontSize="13"
                                                   Foreground="#CCFFFFFF"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </Grid>
